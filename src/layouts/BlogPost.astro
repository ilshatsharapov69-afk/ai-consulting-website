---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import CTABlock from '../components/CTABlock.astro';
import AuthorByline from '../components/AuthorByline.astro';
import { SITE } from '../config';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime, slug, faqs } = Astro.props;
const articleUrl = `${SITE.url}/blog/${slug}/`;

// Get related posts (same tags, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.id !== slug)
  .filter(p => p.data.tags?.some((t: string) => tags?.includes(t)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedDate={pubDate}
  breadcrumbs={[{ name: 'Blog', url: '/blog/' }, { name: title, url: `/blog/${slug}/` }]}
>
  <JsonLd
    type="blogPosting"
    data={{
      title,
      description,
      pubDate: pubDate.toISOString(),
      updatedDate: updatedDate?.toISOString(),
      url: articleUrl,
    }}
  />

  {faqs && faqs.length > 0 && (
    <JsonLd
      type="faqPage"
      data={{ questions: faqs }}
    />
  )}

  <article class="py-12">
    <!-- Header -->
    <header class="max-w-3xl mx-auto px-4 sm:px-6 mb-8 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-navy leading-tight mb-4">
        {title}
      </h1>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 justify-center">
          {tags.map((tag: string) => (
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <AuthorByline pubDate={pubDate} readingTime={readingTime} variant="top" />

    <!-- Hero Image -->
    {heroImage && (
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-12">
        <img src={typeof heroImage === 'string' ? heroImage : heroImage.src} alt={title} class="w-full rounded-xl shadow-lg" />
      </div>
    )}

    <!-- Article content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 prose">
      <slot />
    </div>

    {faqs && faqs.length > 0 && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-16">
        <h2 class="text-2xl font-bold text-navy mb-6">Frequently asked questions</h2>
        <div class="space-y-4">
          {faqs.map((faq: { question: string; answer: string }) => (
            <details class="group rounded-xl border border-gray-200 bg-white p-5 open:border-blue/40 open:shadow-sm transition-all">
              <summary class="flex cursor-pointer items-center justify-between list-none font-semibold text-navy">
                <span>{faq.question}</span>
                <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-gray-600 leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    )}

    <!-- Mid-article CTA (after content) -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-12">
      <CTABlock variant="inline" />
    </div>

    <AuthorByline pubDate={pubDate} readingTime={readingTime} variant="bottom" />

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 mt-12">
        <h3 class="text-xl font-bold text-navy mb-6">Related Articles</h3>
        <div class="space-y-4">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="block no-underline group">
              <div class="p-4 rounded-lg border border-gray-200 hover:border-blue/30 hover:shadow-sm transition-all">
                <div class="text-sm text-gray-500 mb-1">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  <span class="mx-2">·</span>
                  {post.data.readingTime}
                </div>
                <h4 class="font-semibold text-navy group-hover:text-blue transition-colors">{post.data.title}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>

  <!-- Full-width bottom CTA -->
  <CTABlock />
</BaseLayout>
