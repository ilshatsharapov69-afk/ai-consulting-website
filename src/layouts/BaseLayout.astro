---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  breadcrumbs?: Array<{ name: string; url: string }>;
  bodyClass?: string;
}

const { title, description, image, type, publishedDate, breadcrumbs, bodyClass = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} publishedDate={publishedDate} />
    {breadcrumbs && <JsonLd type="breadcrumb" data={{ items: [{ name: 'Home', url: '/' }, ...breadcrumbs] }} />}
  </head>
  <body class:list={['min-h-screen', 'flex', 'flex-col', bodyClass]}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
