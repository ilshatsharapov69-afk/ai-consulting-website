---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);

// Get unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---

<BaseLayout
  title="Blog"
  description="Practical AI guides for small business owners: ChatGPT use cases, AI answering services, software reviews, readiness checklists. Any industry."
  breadcrumbs={[{ name: 'Blog', url: '/blog/' }]}
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-4">Blog</h1>
      <p class="text-lg text-gray-600 mb-8">
        Practical AI guides for small business owners. No hype, no jargon — just tools and strategies that work across any industry.
      </p>

      <!-- Tags -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          {allTags.map((tag) => (
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm hover:bg-blue/10 hover:text-blue transition-colors cursor-default">
              {tag}
            </span>
          ))}
        </div>
      )}

      {featuredPost && (
        <!-- Featured Post -->
        <article class="mb-12">
          <a href={`/blog/${featuredPost.id}/`} class="block no-underline group">
            <div class="p-8 rounded-2xl border-2 border-blue/30 bg-gradient-to-br from-blue/5 to-amber-50/40 hover:border-blue/50 hover:shadow-lg transition-all">
              <div class="flex items-center gap-3 text-sm mb-4">
                <span class="px-2 py-0.5 bg-blue text-white rounded text-xs font-semibold uppercase">
                  {featuredPost.id === 'small-business-data-audit-guide' ? 'Flagship · Methodology' : 'Latest'}
                </span>
                <time datetime={featuredPost.data.pubDate.toISOString()} class="text-gray-500">
                  {featuredPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="text-gray-400">·</span>
                <span class="text-gray-500">{featuredPost.data.readingTime}</span>
              </div>
              <h2 class="text-2xl font-bold text-navy group-hover:text-blue transition-colors mb-3">
                {featuredPost.data.title}
              </h2>
              <p class="text-gray-600 leading-relaxed mb-4">{featuredPost.data.description}</p>
              {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {featuredPost.data.tags.map((tag: string) => (
                    <span class="px-2 py-0.5 bg-white text-gray-500 rounded text-xs border border-gray-200">{tag}</span>
                  ))}
                </div>
              )}
              {featuredPost.id === 'small-business-data-audit-guide' && (
                <div class="inline-flex items-center gap-1 text-sm font-semibold text-blue group-hover:translate-x-1 transition-transform">
                  Read the full methodology
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              )}
            </div>
          </a>
        </article>
      )}

      <!-- Remaining Posts -->
      <div class="space-y-6">
        {remainingPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}/`} class="block no-underline">
              <div class="p-6 rounded-xl border border-gray-200 hover:border-blue/30 hover:shadow-md transition-all">
                <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <span>·</span>
                  <span>{post.data.readingTime}</span>
                </div>
                <h2 class="text-xl font-bold text-navy group-hover:text-blue transition-colors mb-2">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 leading-relaxed">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-3">
                    {post.data.tags.map((tag: string) => (
                      <span class="px-2 py-0.5 bg-gray-100 text-gray-500 rounded text-xs">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-gray-500 text-center py-12">No posts yet. Check back soon!</p>
      )}

      <!-- Quiz CTA -->
      <div class="mt-12 p-6 rounded-xl bg-gray-50 border border-gray-200 text-center">
        <h3 class="text-lg font-bold text-navy mb-2">How AI-Ready Is Your Business?</h3>
        <p class="text-gray-600 text-sm mb-4">Take the free 3-minute quiz and get your AI Readiness Score.</p>
        <a href="/resources/ai-readiness-quiz/" class="inline-flex items-center px-5 py-2.5 rounded-lg bg-blue text-white font-semibold text-sm no-underline hover:bg-blue-light transition-colors">
          Take the Quiz →
        </a>
      </div>
    </div>
  </section>

  <CTABlock />
</BaseLayout>
