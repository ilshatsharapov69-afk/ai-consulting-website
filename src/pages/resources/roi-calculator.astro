---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE } from '../../config';
---

<BaseLayout
  title="AI Savings Calculator"
  description="Estimate how much money AI could save your small business. Pick your industry, enter your numbers, see your potential ROI in 30 seconds."
  breadcrumbs={[{ name: 'Resources', url: '/resources/' }, { name: 'AI Savings Calculator', url: '/resources/roi-calculator/' }]}
>
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-4">How Much Could AI Save Your Business?</h1>
        <p class="text-lg text-gray-600">
          Pick your industry, answer 3-4 questions, get your estimated annual savings in 30 seconds.
          No email required. Based on published industry benchmarks.
        </p>
      </div>

      <!-- Calculator -->
      <div id="calculator" class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8">
        <div class="space-y-6">
          <!-- Industry picker (step 1) -->
          <div>
            <label for="industry" class="block text-sm font-semibold text-navy mb-2">
              Which best describes your business?
            </label>
            <select
              id="industry"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue"
            >
              <option value="service">Service Business (HVAC, Plumbing, Electrical, Cleaning, Home Services, etc.)</option>
              <option value="restaurant">Restaurant / Food Service</option>
              <option value="ecommerce">E-commerce / Retail</option>
              <option value="professional">Professional Services (Accounting, Legal, Consulting, Agencies)</option>
              <option value="other">Other / General</option>
            </select>
          </div>

          <!-- Dynamic inputs (rendered per industry) -->
          <div id="input-fields" class="space-y-6"></div>

          <!-- Calculate Button -->
          <button
            id="calc-btn"
            class="w-full px-6 py-3 rounded-lg bg-blue text-white font-semibold hover:bg-blue-light transition-colors"
          >
            Calculate My Savings
          </button>
        </div>
      </div>

      <!-- Results (hidden initially) -->
      <div id="results" class="hidden mt-8">
        <!-- Total Savings -->
        <div class="text-center p-8 bg-green/5 rounded-2xl border-2 border-green/20 mb-8">
          <div class="text-sm text-gray-500 uppercase tracking-wider mb-2">Estimated Annual Savings</div>
          <div class="text-5xl sm:text-6xl font-bold text-green mb-2" id="total-savings">$0</div>
          <p class="text-gray-600" id="roi-text">That's a <span id="roi-multiple" class="font-bold text-navy">0x</span> return on a $2,500 AI Business Analysis.</p>
        </div>

        <!-- Breakdown -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8 mb-8">
          <h3 class="font-bold text-navy mb-6">Where the Savings Come From</h3>
          <div class="space-y-4" id="savings-breakdown"></div>
          <p class="text-xs text-gray-400 mt-4" id="benchmark-note">
            * Estimates based on published industry benchmarks. Your actual savings depend on your specific situation.
            An AI Business Analysis gives you exact numbers for your business.
          </p>
        </div>

        <!-- CTA -->
        <div class="text-center space-y-4">
          <a
            href={SITE.ctaUrl}
            class="inline-flex items-center px-8 py-4 rounded-lg bg-green text-white font-semibold text-lg no-underline hover:bg-green-light transition-colors"
          >
            {SITE.ctaText}
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <p class="text-sm text-gray-500">
            Want exact numbers? <a href="/services/ai-audit/" class="text-blue font-medium">Learn about our AI Business Analysis</a> — we analyze your actual data.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABlock />
</BaseLayout>

<script>
  type Industry = 'service' | 'restaurant' | 'ecommerce' | 'professional' | 'other';

  const industrySelect = document.getElementById('industry') as HTMLSelectElement;
  const inputFields = document.getElementById('input-fields')!;
  const calcBtn = document.getElementById('calc-btn')!;
  const resultsDiv = document.getElementById('results')!;
  const breakdownEl = document.getElementById('savings-breakdown')!;
  const benchmarkNote = document.getElementById('benchmark-note')!;

  // Render inputs based on industry
  function renderInputs(industry: Industry) {
    const templates: Record<Industry, string> = {
      service: `
        <div>
          <label for="employees" class="block text-sm font-semibold text-navy mb-2">How many employees do you have?</label>
          <input type="range" id="employees" min="3" max="100" value="15" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>3</span><span id="employees-val" class="text-sm font-bold text-navy">15</span><span>100</span></div>
        </div>
        <div>
          <label for="revenue" class="block text-sm font-semibold text-navy mb-2">Approximate annual revenue?</label>
          <select id="revenue" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="500000">$500K - $1M</option>
            <option value="1500000" selected>$1M - $2M</option>
            <option value="3000000">$2M - $5M</option>
            <option value="7500000">$5M - $10M</option>
            <option value="15000000">$10M+</option>
          </select>
        </div>
        <div>
          <label for="missed-calls" class="block text-sm font-semibold text-navy mb-2">What % of incoming calls go unanswered?</label>
          <select id="missed-calls" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="5">Less than 5%</option>
            <option value="15">About 15%</option>
            <option value="30" selected>About 30% (small business average)</option>
            <option value="50">50% or more</option>
            <option value="0">I don't know</option>
          </select>
        </div>
        <div>
          <label for="admin-hours" class="block text-sm font-semibold text-navy mb-2">Hours/week your office staff spends on manual admin?</label>
          <input type="range" id="admin-hours" min="5" max="60" value="20" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5 hrs</span><span id="admin-val" class="text-sm font-bold text-navy">20 hrs</span><span>60 hrs</span></div>
        </div>
      `,
      restaurant: `
        <div>
          <label for="monthly-revenue" class="block text-sm font-semibold text-navy mb-2">Approximate monthly revenue?</label>
          <select id="monthly-revenue" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="50000">$50K/mo</option>
            <option value="100000" selected>$100K/mo</option>
            <option value="250000">$250K/mo</option>
            <option value="500000">$500K/mo</option>
            <option value="1000000">$1M+/mo</option>
          </select>
        </div>
        <div>
          <label for="food-cost-pct" class="block text-sm font-semibold text-navy mb-2">Food cost as % of revenue?</label>
          <input type="range" id="food-cost-pct" min="20" max="45" value="30" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>20%</span><span id="food-cost-val" class="text-sm font-bold text-navy">30%</span><span>45%</span></div>
        </div>
        <div>
          <label for="admin-hours" class="block text-sm font-semibold text-navy mb-2">Hours/week on inventory + scheduling admin?</label>
          <input type="range" id="admin-hours" min="5" max="50" value="15" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5 hrs</span><span id="admin-val" class="text-sm font-bold text-navy">15 hrs</span><span>50 hrs</span></div>
        </div>
      `,
      ecommerce: `
        <div>
          <label for="monthly-revenue" class="block text-sm font-semibold text-navy mb-2">Approximate monthly revenue?</label>
          <select id="monthly-revenue" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="20000">$20K/mo</option>
            <option value="50000">$50K/mo</option>
            <option value="100000" selected>$100K/mo</option>
            <option value="250000">$250K/mo</option>
            <option value="500000">$500K+/mo</option>
          </select>
        </div>
        <div>
          <label for="cart-abandonment" class="block text-sm font-semibold text-navy mb-2">Cart abandonment rate?</label>
          <select id="cart-abandonment" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="50">~50% (great)</option>
            <option value="60">~60%</option>
            <option value="70" selected>~70% (industry average)</option>
            <option value="80">~80% or higher</option>
            <option value="0">I don't know</option>
          </select>
        </div>
        <div>
          <label for="abandon-recovery" class="block text-sm font-semibold text-navy mb-2">Do you have abandoned cart recovery automated?</label>
          <select id="abandon-recovery" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="0" selected>No — nothing automated</option>
            <option value="1">Basic (1 email)</option>
            <option value="2">Full sequence (2-3 emails + SMS)</option>
          </select>
        </div>
        <div>
          <label for="admin-hours" class="block text-sm font-semibold text-navy mb-2">Hours/week on manual order/support tasks?</label>
          <input type="range" id="admin-hours" min="5" max="60" value="15" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5 hrs</span><span id="admin-val" class="text-sm font-bold text-navy">15 hrs</span><span>60 hrs</span></div>
        </div>
      `,
      professional: `
        <div>
          <label for="billable-rate" class="block text-sm font-semibold text-navy mb-2">Average billable hourly rate?</label>
          <select id="billable-rate" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="100">$100/hr</option>
            <option value="200" selected>$200/hr</option>
            <option value="350">$350/hr</option>
            <option value="500">$500/hr</option>
            <option value="750">$750+/hr</option>
          </select>
        </div>
        <div>
          <label for="billable-people" class="block text-sm font-semibold text-navy mb-2">How many billable staff?</label>
          <input type="range" id="billable-people" min="1" max="30" value="5" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>1</span><span id="billable-val" class="text-sm font-bold text-navy">5</span><span>30</span></div>
        </div>
        <div>
          <label for="admin-hours" class="block text-sm font-semibold text-navy mb-2">Hours/week EACH staff spends on non-billable admin?</label>
          <input type="range" id="admin-hours" min="5" max="40" value="20" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5 hrs</span><span id="admin-val" class="text-sm font-bold text-navy">20 hrs</span><span>40 hrs</span></div>
        </div>
      `,
      other: `
        <div>
          <label for="employees" class="block text-sm font-semibold text-navy mb-2">How many employees?</label>
          <input type="range" id="employees" min="1" max="100" value="10" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>1</span><span id="employees-val" class="text-sm font-bold text-navy">10</span><span>100</span></div>
        </div>
        <div>
          <label for="monthly-revenue" class="block text-sm font-semibold text-navy mb-2">Approximate monthly revenue?</label>
          <select id="monthly-revenue" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-base bg-white focus:ring-2 focus:ring-blue focus:border-blue">
            <option value="50000">$50K/mo</option>
            <option value="100000" selected>$100K/mo</option>
            <option value="250000">$250K/mo</option>
            <option value="500000">$500K/mo</option>
            <option value="1000000">$1M+/mo</option>
          </select>
        </div>
        <div>
          <label for="admin-hours" class="block text-sm font-semibold text-navy mb-2">Hours/week your team spends on manual admin tasks?</label>
          <input type="range" id="admin-hours" min="5" max="80" value="25" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5 hrs</span><span id="admin-val" class="text-sm font-bold text-navy">25 hrs</span><span>80 hrs</span></div>
        </div>
      `,
    };

    inputFields.innerHTML = templates[industry];
    wireRangeListeners();
  }

  // Wire up live labels for range inputs
  function wireRangeListeners() {
    const pairs: Array<[string, string, (v: string) => string]> = [
      ['employees', 'employees-val', (v) => v],
      ['admin-hours', 'admin-val', (v) => `${v} hrs`],
      ['food-cost-pct', 'food-cost-val', (v) => `${v}%`],
      ['billable-people', 'billable-val', (v) => v],
    ];
    for (const [inputId, labelId, fmt] of pairs) {
      const input = document.getElementById(inputId) as HTMLInputElement | null;
      const label = document.getElementById(labelId);
      if (input && label) {
        input.addEventListener('input', () => { label.textContent = fmt(input.value); });
      }
    }
  }

  // Utility
  const $ = (id: string) => document.getElementById(id);
  const val = (id: string): number => {
    const el = $(id) as HTMLInputElement | HTMLSelectElement | null;
    return el ? parseFloat(el.value || '0') : 0;
  };

  // Industry-specific calculators
  interface SavingsRow { label: string; desc: string; amount: number; }
  interface CalcResult { rows: SavingsRow[]; total: number; note: string; }

  function calcService(): CalcResult {
    const employees = val('employees');
    const revenue = val('revenue'); // annual
    let missedPct = val('missed-calls');
    const adminHours = val('admin-hours');
    if (missedPct === 0) missedPct = 30; // default when "I don't know"

    // Missed call recovery: conservative. Baseline: small biz miss 62% on average (411 Locals),
    // we use user's value. Assume ~15 calls/employee/month, 35% conversion to jobs,
    // avg ticket = revenue / (employees * 100) roughly — cap at $2,500.
    const callsPerMonth = employees * 15;
    const missedCalls = callsPerMonth * (missedPct / 100) * 12;
    const avgTicket = Math.min(revenue / Math.max(employees * 100, 1), 2500);
    const savingsCalls = Math.round(missedCalls * 0.35 * avgTicket);

    // Admin time: McKinsey 60-70% automation potential. Conservative 35% reduction × $25/hr × 52 weeks.
    const savingsAdmin = Math.round(adminHours * 0.35 * 25 * 52);

    // Operational efficiency: 2% revenue uplift from better quoting, scheduling, follow-ups.
    const savingsOps = Math.round(revenue * 0.02);

    const rows: SavingsRow[] = [
      { label: 'Missed Call Recovery', desc: 'AI answering captures leads 24/7', amount: savingsCalls },
      { label: 'Admin Time Reduction', desc: 'AI automates 35% of manual tasks (McKinsey 60-70% automation potential)', amount: savingsAdmin },
      { label: 'Operational Efficiency', desc: 'Faster quoting + scheduling + follow-ups = 2% revenue uplift', amount: savingsOps },
    ];
    return {
      rows,
      total: rows.reduce((s, r) => s + r.amount, 0),
      note: 'Based on 411 Locals small business call data, McKinsey automation research, and industry operational benchmarks.',
    };
  }

  function calcRestaurant(): CalcResult {
    const monthlyRev = val('monthly-revenue');
    const annualRev = monthlyRev * 12;
    const foodCostPct = val('food-cost-pct') / 100;
    const adminHours = val('admin-hours');

    const annualFoodCost = annualRev * foodCostPct;
    // NRA/LeanPath: commercial kitchens waste 4-10% of food purchased.
    // Winnow: AI reduces food waste up to 50%, food costs 3-8%.
    // Conservative: 5% waste reduction on 7% baseline = ~$2,450 saved per $1M food cost = ~0.25% of rev.
    // Use 4% of annual food cost as reasonable AI-driven saving.
    const savingsFoodWaste = Math.round(annualFoodCost * 0.04);

    // Admin automation: 35% reduction × $22/hr avg restaurant admin × 52 weeks.
    const savingsAdmin = Math.round(adminHours * 0.35 * 22 * 52);

    // Customer retention via CRM / loyalty: 1% revenue uplift from repeat customer programs.
    const savingsRetention = Math.round(annualRev * 0.01);

    const rows: SavingsRow[] = [
      { label: 'Food Waste Reduction', desc: 'AI inventory tools reduce waste 4% of food cost (NRA/LeanPath baseline, Winnow benchmarks)', amount: savingsFoodWaste },
      { label: 'Admin Time Reduction', desc: 'AI automates 35% of inventory + scheduling admin', amount: savingsAdmin },
      { label: 'Repeat Customer Uplift', desc: 'CRM + loyalty automation = 1% revenue uplift', amount: savingsRetention },
    ];
    return {
      rows,
      total: rows.reduce((s, r) => s + r.amount, 0),
      note: 'Based on National Restaurant Association / LeanPath food waste data, Winnow AI benchmarks, and industry retention research.',
    };
  }

  function calcEcommerce(): CalcResult {
    const monthlyRev = val('monthly-revenue');
    const annualRev = monthlyRev * 12;
    let abandonPct = val('cart-abandonment');
    const recoveryLevel = val('abandon-recovery'); // 0 = none, 1 = basic, 2 = full
    const adminHours = val('admin-hours');
    if (abandonPct === 0) abandonPct = 70; // default

    // Baymard 70.19% baseline. Klaviyo: abandoned cart flows drive the highest RPR of any email flow.
    // If no recovery: huge opportunity. If basic: moderate. If full: marginal.
    // Conservative: assume current revenue reflects current state; potential uplift from improving cart recovery:
    //   no recovery → ~8% revenue uplift
    //   basic → ~3% revenue uplift
    //   full → ~1% revenue uplift (already captured)
    const recoveryUplift = recoveryLevel === 0 ? 0.08 : recoveryLevel === 1 ? 0.03 : 0.01;
    const savingsCart = Math.round(annualRev * recoveryUplift);

    // Email automation uplift: 3% revenue uplift from flows beyond cart (welcome, post-purchase, winback).
    const savingsEmail = Math.round(annualRev * 0.03);

    // Admin automation: 35% reduction × $22/hr × 52 weeks.
    const savingsAdmin = Math.round(adminHours * 0.35 * 22 * 52);

    const rows: SavingsRow[] = [
      { label: 'Cart Recovery Uplift', desc: `Abandoned cart automation — ${recoveryLevel === 0 ? 'huge untapped opportunity' : recoveryLevel === 1 ? 'full sequence upgrade' : 'fine-tuning existing flows'} (Baymard, Klaviyo benchmarks)`, amount: savingsCart },
      { label: 'Email Automation Uplift', desc: 'Welcome, post-purchase, and winback flows = 3% revenue uplift', amount: savingsEmail },
      { label: 'Admin Time Reduction', desc: 'AI automates 35% of order + support tasks', amount: savingsAdmin },
    ];
    return {
      rows,
      total: rows.reduce((s, r) => s + r.amount, 0),
      note: 'Based on Baymard Institute (70% cart abandonment baseline), Klaviyo automation benchmarks, and McKinsey automation research.',
    };
  }

  function calcProfessional(): CalcResult {
    const hourlyRate = val('billable-rate');
    const people = val('billable-people');
    const adminHours = val('admin-hours');

    // Clio 2024: lawyers bill 2.9 of 8 hrs/day (37% utilization). 74% of billable work is AI-automatable.
    // Reclaim 50% of admin hours as potential billable (conservative).
    const weeklyReclaimed = adminHours * people * 0.50;
    const annualReclaimedHours = weeklyReclaimed * 50; // 50 working weeks
    const savingsBillable = Math.round(annualReclaimedHours * hourlyRate * 0.7); // 70% realization

    // Direct admin cost savings: 35% reduction × $30/hr blended admin cost × people × 52.
    const savingsAdmin = Math.round(adminHours * 0.35 * 30 * people * 52);

    // Faster turnaround uplift: 2% more client work completed = 2% revenue.
    const annualRevenueEstimate = hourlyRate * 1500 * people; // 1500 billable hrs/yr approx if utilization rose
    const savingsThroughput = Math.round(annualRevenueEstimate * 0.02);

    const rows: SavingsRow[] = [
      { label: 'Reclaimed Billable Hours', desc: 'Reclaim 50% of admin time as billable work (Clio 2024: 74% of hourly work is AI-automatable)', amount: savingsBillable },
      { label: 'Direct Admin Cost Reduction', desc: 'AI automates 35% of non-billable admin across staff', amount: savingsAdmin },
      { label: 'Throughput / Turnaround Uplift', desc: 'Faster proposals + document drafting = 2% more client work done', amount: savingsThroughput },
    ];
    return {
      rows,
      total: rows.reduce((s, r) => s + r.amount, 0),
      note: 'Based on Clio 2024 Legal Trends Report (lawyer utilization + AI automation), McKinsey automation research.',
    };
  }

  function calcOther(): CalcResult {
    const employees = val('employees');
    const monthlyRev = val('monthly-revenue');
    const annualRev = monthlyRev * 12;
    const adminHours = val('admin-hours');

    // Generic admin automation: 35% reduction × $25/hr × 52.
    const savingsAdmin = Math.round(adminHours * 0.35 * 25 * 52);

    // Generic operational uplift: 1.5% revenue from finding leaks.
    const savingsOps = Math.round(annualRev * 0.015);

    // Revenue per employee uplift proxy: conservative flat $1,000/employee/yr saving from better data use.
    const savingsDataUse = Math.round(employees * 1000);

    const rows: SavingsRow[] = [
      { label: 'Admin Time Reduction', desc: 'AI automates 35% of manual admin tasks (McKinsey)', amount: savingsAdmin },
      { label: 'Operational Efficiency', desc: 'Finding leaks in orders/scheduling/followups = 1.5% revenue uplift', amount: savingsOps },
      { label: 'Better Data Use', desc: 'Per-employee productivity gain from AI-enabled workflows (Forrester: 60-73% of data never analyzed)', amount: savingsDataUse },
    ];
    return {
      rows,
      total: rows.reduce((s, r) => s + r.amount, 0),
      note: 'Conservative cross-industry estimate based on McKinsey automation research and Forrester data usage research.',
    };
  }

  const calculators: Record<Industry, () => CalcResult> = {
    service: calcService,
    restaurant: calcRestaurant,
    ecommerce: calcEcommerce,
    professional: calcProfessional,
    other: calcOther,
  };

  function renderResults(result: CalcResult) {
    const totalEl = $('total-savings')!;
    totalEl.textContent = `$${result.total.toLocaleString()}`;
    $('roi-multiple')!.textContent = `${(result.total / 2500).toFixed(1)}x`;

    breakdownEl.innerHTML = result.rows.map(r => `
      <div class="flex items-center justify-between p-4 rounded-lg bg-gray-50">
        <div class="pr-4">
          <div class="font-semibold text-navy">${r.label}</div>
          <div class="text-sm text-gray-500">${r.desc}</div>
        </div>
        <div class="text-xl font-bold text-blue whitespace-nowrap">$${r.amount.toLocaleString()}/yr</div>
      </div>
    `).join('');

    benchmarkNote.textContent = `* ${result.note} An AI Business Analysis gives you exact numbers for your business.`;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  industrySelect.addEventListener('change', () => {
    renderInputs(industrySelect.value as Industry);
    resultsDiv.classList.add('hidden');
  });

  calcBtn.addEventListener('click', () => {
    const industry = industrySelect.value as Industry;
    const result = calculators[industry]();
    renderResults(result);
  });

  // Initial render
  renderInputs(industrySelect.value as Industry);
</script>
