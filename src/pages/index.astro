---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../config';
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <JsonLd type="organization" />

  <!-- 1. HERO — open loop -->
  <section class="bg-navy text-white py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6">
            Your Business Has More Data Than You Think. Most of It Hides Money Leaks.
          </h1>
          <p class="text-lg sm:text-xl text-gray-300 mb-4 leading-relaxed">
            We run AI analysis on your small business data — CRM exports, spreadsheets, calendar, POS, invoices — and deliver a report showing every dollar you're losing. <strong class="text-white">$2,500. Takes 5-7 days. Any industry.</strong>
          </p>
          <div class="mt-8">
            <a
              href={SITE.ctaUrl}
              class="inline-flex items-center px-6 py-3 rounded-lg bg-green text-white font-semibold text-lg no-underline hover:bg-green-light transition-colors shadow-lg hover:shadow-xl"
            >
              {SITE.ctaText}
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <p class="text-gray-400 text-sm mt-3">You'll walk away knowing your top 3 money leaks — even if you never hire us.</p>
            <a href={SITE.social.youtube} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-4 text-sm text-gray-300 hover:text-white no-underline transition-colors">
              <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              Just watched the breakdown on YouTube? This is the next step →
            </a>
          </div>
          <!-- Open loop — scroll hook -->
          <div class="mt-10 flex items-center gap-2 text-gray-400 text-sm">
            <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
            Scroll down to see what AI finds across 5 real small business audits
          </div>
        </div>
        <div class="hidden lg:flex justify-center">
          <!-- TODO: replace with VSL iframe when recorded. See handoff notes Research prompt #2. -->
          <a
            href={SITE.social.youtube}
            target="_blank"
            rel="noopener"
            class="w-full max-w-md aspect-video rounded-2xl bg-white/10 hover:bg-white/15 transition-colors flex flex-col items-center justify-center p-6 no-underline group"
          >
            <svg class="w-20 h-20 text-red-500 mb-4 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <div class="text-white font-semibold text-lg text-center">Watch the AI Audit Breakdowns</div>
            <div class="text-gray-300 text-sm mt-2">on @Ilshatai — where these findings come from</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. TRUST BAR -->
  <section class="border-b border-gray-200 bg-white py-6">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-navy">6+</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Industries Covered</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-navy">10,000+</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Data Points Per Analysis</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-navy">5-7 Days</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Report Delivery</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-navy">$2,500</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Flat Fee. No Surprises.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SOUND FAMILIAR? (Recognition) -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">
        Sound Familiar?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          "You were slammed all quarter, but the P&L doesn't show it. Where did the money go?",
          "Your best employee just quit — and years of undocumented know-how walked out the door.",
          "A competitor just ate your market share with a faster response time — and you can't figure out what they're doing differently.",
          "Your office manager is drowning in paperwork. Again. And she's already doing the work of three people.",
        ].map((text) => (
          <div class="p-6 rounded-xl border border-gray-200 bg-white">
            <p class="text-gray-700 text-lg leading-relaxed italic">"{text}"</p>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-500 mt-8">These are the moments when small business owners call us.</p>
    </div>
  </section>

  <!-- 4. COST OF WAITING (Anxiety) -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8">
        Every Month You Wait Is Another Month of Losses
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
        <div>
          <div class="text-3xl font-bold text-red-400 mb-2">60-73%</div>
          <p class="text-gray-300 text-sm">of business data never gets analyzed — every invoice, transaction, and record you generate sits untouched while competitors mine theirs. (Forrester Research)</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-red-400 mb-2">58%</div>
          <p class="text-gray-300 text-sm">of US small businesses now use AI — up from 23% two years ago. The gap between adopters and holdouts is widening every quarter. (U.S. Chamber of Commerce, 2025)</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-red-400 mb-2">$0</div>
          <p class="text-gray-300 text-sm">is what it costs to find out if you have these problems. The free call takes 20 minutes. The answer might save you six figures.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. WHAT AI FINDS (Hope — before/after) -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-4">
        What AI Actually Finds
      </h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        Representative findings from data audits across industries. Every number is sourced.
      </p>
      <div class="space-y-6">
        <!-- Before/After cards -->
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-blue">70%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">E-commerce: Cart Abandonment</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> 70% of carts abandoned — industry baseline.
                <span class="text-green font-medium">After:</span> Automated recovery flows are the highest-revenue email type for Shopify/WooCommerce stores, averaging $3.65 per recipient.
              </p>
              <p class="text-xs text-gray-400 mt-1">Baymard Institute (2025), Klaviyo benchmarks</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-xl font-bold text-blue">4-10%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">Restaurants: Food Waste</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> Commercial kitchens waste 4-10% of food purchased — $40K-$100K/yr on a $1M food budget.
                <span class="text-green font-medium">After:</span> AI inventory tools cut food waste up to 50% and food costs 3-8%.
              </p>
              <p class="text-xs text-gray-400 mt-1">National Restaurant Association / LeanPath; Winnow case data (2024)</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-blue">37%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">Professional Services: Billable-Hour Leakage</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> Lawyers bill just 2.9 hours of an 8-hour day — 37% utilization.
                <span class="text-green font-medium">After:</span> 74% of hourly billable work (drafting, retrieval, analysis) is automatable by AI.
              </p>
              <p class="text-xs text-gray-400 mt-1">Clio 2024 Legal Trends Report</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-blue">62%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">Home Services: Missed Calls</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> In a 30-day study of 85 small businesses across 58 industries, only 37.8% of incoming calls were answered live.
                <span class="text-green font-medium">After:</span> 24/7 AI answering captures every lead — calls that used to go to voicemail now book appointments.
              </p>
              <p class="text-xs text-gray-400 mt-1">411 Locals research study</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-xl font-bold text-blue">20-50%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">Retail & Inventory: Dead Stock Cut</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> Inventory distortion costs global retailers $1.73T/yr — 6.5% of total retail sales.
                <span class="text-green font-medium">After:</span> AI demand forecasting reduces inventory levels 20-50% and improves forecast accuracy from 75% to 90%+.
              </p>
              <p class="text-xs text-gray-400 mt-1">IHL Group (2025); McKinsey distribution operations research</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-16 h-16 rounded-lg bg-blue/10 flex items-center justify-center">
              <span class="text-xl font-bold text-blue">60-70%</span>
            </div>
            <div>
              <h3 class="font-bold text-navy mb-1">All Industries: Admin Automation Potential</h3>
              <p class="text-gray-600">
                <span class="text-red-500 font-medium">Before:</span> Office staff buried in repetitive admin — drafting, lookups, data entry, scheduling.
                <span class="text-green font-medium">After:</span> Current AI can automate 60-70% of activities that consume employee time across industries.
              </p>
              <p class="text-xs text-gray-400 mt-1">McKinsey Global Institute, "The Economic Potential of Generative AI" (June 2023)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WHAT YOU GET — scope + value stack (Desire) -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">
        What You Get for $2,500
      </h2>
      <div class="bg-white rounded-2xl border-2 border-blue p-8 sm:p-10">
        <div class="flex items-baseline justify-between mb-8">
          <h3 class="text-2xl font-bold text-navy">AI Business Analysis</h3>
          <div class="text-right">
            <span class="text-3xl font-bold text-blue">$2,500</span>
            <span class="text-gray-500 block text-sm">one-time</span>
          </div>
        </div>

        <!-- Deliverables -->
        <div class="space-y-4 mb-8">
          <h4 class="font-semibold text-navy">What's included:</h4>
          {[
            '12-20 page PDF report with your AI Readiness Score',
            '8-15 scored opportunities ranked by impact and ROI',
            'Exact dollar amounts — what you\'re losing, where, and how much you\'d save',
            '30/60/90 day action plan with specific tools and costs',
            '60-minute walkthrough call — we go through every finding together',
          ].map((item) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">{item}</span>
            </div>
          ))}
        </div>

        <!-- Value stack -->
        <div class="p-5 bg-blue/5 rounded-lg mb-8">
          <h4 class="font-semibold text-navy mb-3">What this analysis is worth:</h4>
          <div class="space-y-2 text-sm">
            {[
              { item: 'Business process audit (6 dimensions)', value: '$1,500' },
              { item: 'Technology stack review & integration mapping', value: '$800' },
              { item: 'AI opportunity mapping (8-15 use cases)', value: '$2,000' },
              { item: 'ROI calculation per opportunity', value: '$1,200' },
              { item: '30/60/90 day action plan', value: '$500' },
            ].map((row) => (
              <div class="flex justify-between">
                <span class="text-gray-600">{row.item}</span>
                <span class="text-gray-400">{row.value}</span>
              </div>
            ))}
            <div class="border-t border-gray-200 pt-2 mt-3 flex justify-between font-semibold">
              <span class="text-gray-500">Total value</span>
              <span class="text-gray-400 line-through">$6,000+</span>
            </div>
            <div class="flex justify-between text-lg font-bold">
              <span class="text-navy">Your investment</span>
              <span class="text-blue">$2,500</span>
            </div>
          </div>
        </div>

        <!-- What's NOT included -->
        <div class="space-y-3 p-4 bg-gray-50 rounded-lg mb-6">
          <h4 class="font-semibold text-navy">What's NOT included (we're upfront):</h4>
          {[
            'We don\'t implement anything — this is analysis only',
            'We don\'t sell you software',
            'You get the report and decide what to do with it',
          ].map((item) => (
            <div class="flex items-start gap-3">
              <span class="text-gray-400 shrink-0">—</span>
              <span class="text-gray-600 text-sm">{item}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap gap-6 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            5-7 business days
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            ~3 hours of your time
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. HOW IT WORKS -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">
        How It Works
      </h2>
      <div class="space-y-8">
        {[
          { n: 1, title: 'Free call (20 min)', desc: 'We talk about your business. You tell us the headaches. We figure out if our analysis can actually help. If not, we\'ll say so.' },
          { n: 2, title: 'We pull your data', desc: 'From systems you already use — QuickBooks, Stripe, Shopify, Toast, Salesforce, Google Calendar, Excel, or whatever your business runs on. We work with what you have. No extra work for you.' },
          { n: 3, title: 'AI analyzes everything', desc: 'Thousands of data points — orders, transactions, schedules, customer records, costs. AI finds patterns that no person has time to look for.' },
          { n: 4, title: 'You get the report', desc: 'PDF + 60-minute walkthrough. Every finding explained with dollar amounts. The report is yours to keep and act on however you want.' },
        ].map((step) => (
          <div class="flex gap-4">
            <div class="shrink-0 w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-bold text-lg">
              {step.n}
            </div>
            <div>
              <h3 class="text-lg font-bold text-navy mb-1">{step.title}</h3>
              <p class="text-gray-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. ZERO RISK -->
  <section class="py-16 bg-green/5">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-16 h-16 rounded-full bg-green/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-4">
        Zero Risk
      </h2>
      <p class="text-lg text-gray-700 leading-relaxed">
        If our report doesn't identify at least <strong>$25,000 in annual savings opportunities</strong>, we refund the full $2,500. No questions asked.
      </p>
    </div>
  </section>

  <!-- 9. WHY NOT JUST... (Objections) -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">
        "Why Can't I Just..."
      </h2>
      <div class="space-y-6">
        <details>
          <summary>"...use ChatGPT myself?"</summary>
          <div>
            You can — and you should, for basic tasks like drafting emails, rewriting product descriptions, or summarizing documents. But analyzing 2,000 customer records, cross-referencing with transaction history, and finding patterns across 12 months of data? That takes specialized AI tools and someone who knows what to look for. ChatGPT is a calculator. We're the accountant.
          </div>
        </details>
        <details>
          <summary>"...just buy better software?"</summary>
          <div>
            Software solves one problem. Analysis tells you WHICH problem to solve first — and whether new software is even the answer. Small businesses who bought all-in-one platforms (Shopify Plus, ServiceTitan, Toast, Salesforce) without a plan often spent $10,000-$25,000 on implementation and took 6-8 months to go live. Some never did. Analysis first, software second.
          </div>
        </details>
        <details>
          <summary>"...have my office manager figure this out?"</summary>
          <div>
            She's already doing the work of three people — admin, bookkeeping, customer service, scheduling. She doesn't have 40 hours to dig through transaction logs and customer histories. And she doesn't have AI tools that process 10,000 records in minutes. This isn't about capability — it's about time and tools.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- 10. LIMITED CAPACITY (Urgency) -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl sm:text-2xl font-bold text-navy mb-3">
        We Work With 4 Small Businesses Per Month
      </h2>
      <p class="text-gray-600">
        Every analysis gets our full attention — no templates, no rushing. This means availability is limited.
        If we're booked, we'll let you know the next available slot.
      </p>
    </div>
  </section>

  <!-- 11. FREE CALL CTA -->
  <section class="bg-navy py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
        Free Call — Here's What You Get
      </h2>
      <p class="text-gray-300 text-lg mb-4">20 minutes. Free. No pitch.</p>
      <div class="text-left max-w-md mx-auto mb-8 space-y-3">
        {[
          'Your 3 biggest operational money leaks',
          'A rough dollar estimate of what they cost you',
          'Whether AI analysis makes sense for your business size and industry',
        ].map((item) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-200">{item}</span>
          </div>
        ))}
      </div>
      <p class="text-gray-400 text-sm mb-8">Even if you never hire us.</p>
      <a
        href={SITE.ctaUrl}
        class="inline-flex items-center px-8 py-4 rounded-lg bg-green text-white font-semibold text-lg no-underline hover:bg-green-light transition-colors shadow-lg"
      >
        {SITE.ctaText}
