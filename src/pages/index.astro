---
import BaseLayout from '../layouts/BaseLayout.astro';
import GrainyAurora from '../components/GrainyAurora.astro';
import DifferenceTable from '../components/DifferenceTable.astro';
import SampleAuditPreview from '../components/SampleAuditPreview.astro';
import PractitionerNote from '../components/PractitionerNote.astro';
import SelfAssessment from '../components/SelfAssessment.astro';
import JsonLd from '../components/JsonLd.astro';
import Preloader from '../components/Preloader.astro';
import AmbientDataParticles from '../components/AmbientDataParticles.astro';
import LiveRevenueChart from '../components/LiveRevenueChart.astro';
import CountUpMetric from '../components/CountUpMetric.astro';
import SocialProofStrip from '../components/SocialProofStrip.astro';
import SignalDivider from '../components/SignalDivider.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import PhaseIcon from '../components/PhaseIcon.astro';
import { SITE } from '../config';

const heroPart1 = "Your small business data knows where the money's leaking.";
const heroPart2 = "Most owners never ask it.";

let heroCharIdx = 0;
const buildWords = (line: string) =>
  line.split(' ').map((word) => ({
    chars: [...word].map((c) => ({ c, i: heroCharIdx++ })),
  }));
const heroWords1 = buildWords(heroPart1);
const heroWords2 = buildWords(heroPart2);

const authorityMetrics = [
  { num: '5 days', label: 'intake to delivery' },
  { num: '20 min', label: 'discovery call · no pitch' },
  { num: '14 pages', label: 'sample audit before you pay' },
  { num: '$500K–$10M', label: 'revenue range I work with' },
];

const painQuotes = [
  "You were slammed all quarter, but the P&L doesn't show it. Where did the money go?",
  "Your best employee just quit — and years of undocumented know-how walked out the door.",
  "A competitor just ate your market share with a faster response time.",
  "Your office manager is drowning in paperwork. Again.",
];

const phases = [
  {
    num: '01',
    name: 'Discovery call',
    desc: 'Twenty minutes. I listen for the leak you can already feel. By the end, you know whether the audit fits — and three things to look at even if it does not.',
  },
  {
    num: '02',
    name: 'Data intake',
    desc: 'Exports from whatever you already use — QuickBooks, Stripe, Shopify, Toast, Salesforce, Google Calendar, Excel. No new software, no integration project.',
  },
  {
    num: '03',
    name: 'Analysis',
    desc: 'I read your data the way an outside accountant reads a P&L. Patterns no one inside the business has time to look for, surfaced and quantified in dollars.',
  },
  {
    num: '04',
    name: 'Delivery',
    desc: 'A 14-page PDF and a 60-minute walkthrough. Every finding tied to a number. A 30/60/90 plan you can execute alone or hand to anyone.',
  },
];

const faqs = [
  {
    q: "Can't I just use ChatGPT myself?",
    a: "You can — and you should, for drafting and summarizing. But analyzing 2,000 customer records, cross-referencing twelve months of transactions, and surfacing patterns nobody has time to look for needs specialized tooling and someone who knows the signals. ChatGPT is a calculator. The audit is the accountant.",
  },
  {
    q: 'Why not just buy better software?',
    a: "Software solves one problem. Analysis tells you which problem to solve first — and whether new software is even the right answer. Most owners who buy all-in-one platforms without a plan spend $10K–$25K on implementation and wait months for payoff. Analysis first, software second.",
  },
  {
    q: 'What if my data is messy?',
    a: "Messy data is the norm — exports with blanks, inconsistent formats, legacy fields. Cleaning is the first day or two of the audit. If the data genuinely cannot be analyzed, I tell you on the discovery call before you commit.",
  },
  {
    q: "I'm not sure AI can help my specific industry.",
    a: "The methodology is industry-agnostic because the data types are — CRM records, POS transactions, calendars, invoices show up everywhere. On the discovery call you tell me what systems you run; I tell you honestly whether the audit fits.",
  },
  {
    q: 'Can my office manager figure this out?',
    a: "She is already doing the work of three people — admin, bookkeeping, customer service, scheduling. She does not have forty hours to dig through transaction logs, and she does not have AI tools that read ten thousand records in minutes. This is not about capability. It is about time and tools.",
  },
  {
    q: 'Why $2,500? Why fixed?',
    a: "Fixed price means I stop the clock at 5 days whether the audit took 30 hours or 60. Methodology scales; my time does not. If your data would take more than a week to read, I tell you on the discovery call and we both walk away — no invoice, no obligation.",
  },
  {
    q: "What if the audit doesn't find anything valuable?",
    a: "Then I refund the full $2,500. I track every finding against your fee, and if the total dollar impact doesn't clear $2,500 by day 5, you get the audit deliverable for free and the money back. Falsifiable, no fine print.",
  },
];
---

<BaseLayout title={SITE.name} description={SITE.description} bodyClass="home">
  <JsonLd type="organization" />
  <Preloader />

  <svg aria-hidden="true" class="grain-defs" width="0" height="0">
    <defs>
      <filter id="grain-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </defs>
  </svg>

  {/* SECTION 1 — HERO */}
  <GrainyAurora class="hero">
    <AmbientDataParticles count={30} />
    <div class="hero-inner">
      <div class="hero-main">
        <a href={SITE.social.youtube} target="_blank" rel="noopener" class="authority-badge">
          <img
            src="/assets/founder-avatar-round.jpg"
            alt=""
            class="avatar-48"
            width="72"
            height="72"
            loading="eager"
            decoding="async"
            onerror="this.style.display='none';"
          />
          <span>As seen on <strong>@Ilshatai</strong> on YouTube</span>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="margin-left:4px;opacity:0.65;">
            <path d="M6 3h7v7M13 3L5.5 10.5M3 6v7h7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <h1 class="hero-display kinetic-headline">
          <span class="hero-line">
            {heroWords1.flatMap((w, wi) => [
              <span class="kinetic-word">
                {w.chars.map((ch) => (
                  <span class="kinetic-char" style={`--char-i: ${ch.i}`}>{ch.c}</span>
                ))}
              </span>,
              wi < heroWords1.length - 1 ? ' ' : '',
            ])}
          </span>
          <span class="hero-line">
            {heroWords2.flatMap((w, wi) => [
              <span class="kinetic-word">
                {w.chars.map((ch) => (
                  <span class="kinetic-char" style={`--char-i: ${ch.i}`}>{ch.c}</span>
                ))}
              </span>,
              wi < heroWords2.length - 1 ? ' ' : '',
            ])}
          </span>
        </h1>

        <p class="hero-sub">
          I read your QuickBooks, your CRM, your calendar — then I tell you where the
          money you can feel but cannot point at is hiding. One person, five days, fixed
          price. For US small businesses doing $500K–$10M.
        </p>

        <div class="hero-cta-wrap">
          <a href="#sample-audit-preview" class="cta-primary magnetic">
            See a sample audit page <span class="cta-arrow">→</span>
          </a>
          <a href={SITE.calUrl} target="_blank" rel="noopener" class="cta-secondary">
            Or skip the preview — book a 20-min call
          </a>
          <p class="hero-price-pill">$2,500 · 5 days · fixed · audit-or-refund</p>
        </div>
      </div>

      <aside class="hero-visual" aria-label="Sample 12-month revenue with quantified leak moments">
        <LiveRevenueChart />
      </aside>
    </div>
  </GrainyAurora>

  {/* SECTION 2 — AUTHORITY STRIP (count-up metrics) */}
  <section class="authority-strip" aria-label="Audit at a glance">
    <div class="authority-inner">
      <CountUpMetric target="5 days" label="intake to delivery" />
      <CountUpMetric target="20 min" label="discovery call · no pitch" />
      <CountUpMetric target="14 pages" label="sample audit before you pay" />
      <CountUpMetric target="$500K–$10M" label="revenue range I work with" mode="type" duration={1600} />
    </div>
  </section>

  <SignalDivider variant="ekg" theme="dark" />

  {/* SECTION 2.5 — SOCIAL PROOF STRIP (marquee) */}
  <SocialProofStrip />

  {/* SECTION 3 — SOUND FAMILIAR */}
  <section class="sound-familiar">
    <div class="sf-inner">
      <h2 class="sf-heading">Sound familiar?</h2>
      <div class="sf-wall">
        {painQuotes.map((q, i) => (
          <blockquote class={`sf-card reveal sf-card-${i + 1}`}>
            <p>&ldquo;{q}&rdquo;</p>
          </blockquote>
        ))}
      </div>
      <p class="sf-caption">These are the moments owners call me.</p>
    </div>
  </section>

  <SignalDivider variant="candle" theme="light" />

  {/* SECTION 4 — DIFFERENCE TABLE */}
  <DifferenceTable />

  {/* SECTION 5 — SAMPLE AUDIT PREVIEW (now with mini bar charts per finding) */}
  <SampleAuditPreview />

  <SignalDivider variant="spark" theme="light" />

  {/* SECTION 6 — DATA-TO-DOLLARS PROCESS (with animated phase icons) */}
  <section class="process">
    <div class="process-inner">
      <h2 class="process-heading">The Data-to-Dollars process.</h2>
      <div class="process-phases">
        {phases.map((p, idx) => (
          <div class="phase reveal">
            <PhaseIcon phase={(idx + 1) as 1 | 2 | 3 | 4} />
            <span class="phase-num" aria-hidden="true">{p.num}</span>
            <div class="phase-text">
              <h3 class="phase-name">{p.name}</h3>
              <p class="phase-desc">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* SECTION 6.5 — BEFORE/AFTER SLIDER (chaotic dashboard → clean audit) */}
  <BeforeAfterSlider />

  <SignalDivider variant="dots" theme="light" />

  {/* SECTION 7 — SELF-ASSESSMENT (now with email capture) */}
  <SelfAssessment />

  {/* SECTION 8 — PRACTITIONER NOTE (2-column with real portrait) */}
  <PractitionerNote />

  {/* SECTION 8.5 — SCOPE & PRICING */}
  <section class="scope-pricing" id="scope-pricing">
    <div class="scope-inner">
      <h2 class="scope-heading">What $2,500 buys you.</h2>
      <div class="scope-grid">
        <div class="scope-col">
          <div class="scope-label">Deliverable</div>
          <p class="scope-text">14-page PDF + 60-minute walkthrough + a 30/60/90 action plan you can hand to anyone.</p>
        </div>
        <div class="scope-col">
          <div class="scope-label">Timeline</div>
          <p class="scope-text">Five working days from the moment your data lands in my inbox. I quote the exact delivery date on the discovery call.</p>
        </div>
        <div class="scope-col">
          <div class="scope-label">Scope</div>
          <p class="scope-text">One business, cross-industry, $500K–$10M revenue. No retainers. No Phase 2. If the discovery call shows scope is bigger than 5 days, I tell you and you walk away.</p>
        </div>
      </div>
      <div class="scope-guarantee">
        <span class="scope-guarantee-label">Audit-or-refund guarantee</span>
        <p class="scope-guarantee-text">
          If during my 5-day analysis I find nothing worth more than your $2,500 fee, I refund the full amount. Falsifiable. No fine print.
        </p>
      </div>
    </div>
  </section>

  {/* SECTION 9 — FAQ */}
  <section class="faq">
    <div class="faq-inner">
      <h2 class="faq-heading">The usual questions.</h2>
      {faqs.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <div>{item.a}</div>
        </details>
      ))}
    </div>
  </section>

  <SignalDivider variant="ekg" theme="light" />

  {/* SECTION 10 — FINAL CTA */}
  <GrainyAurora class="final-cta">
    <AmbientDataParticles count={20} class="particles-reverse" />
    <div class="final-inner">
      <h2 class="final-heading">
        Your data is already paying for the audit. You just cannot see it yet.
      </h2>
      <p class="final-sub">
        Twenty minutes. I review what you already have beforehand. You leave with three
        findings — yours to keep, no follow-up sequence.
      </p>
      <a href={SITE.calUrl} target="_blank" rel="noopener" class="cta-primary magnetic">
        Book a 20-min discovery call <span class="cta-arrow">→</span>
      </a>
      <div class="final-signature">
        <img
          src="/assets/founder-avatar-round.jpg"
          alt=""
          width="80"
          height="80"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none';"
        />
        <span>— Ilshat, practitioner · 4 audits / month</span>
      </div>
    </div>
  </GrainyAurora>
</BaseLayout>

<script>
  // Always run IntersectionObserver — reliable across all browsers.
  // (Native animation-timeline is opt-in via .reveal-native class only.)
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  const fineAndMotion =
    matchMedia('(pointer: fine)').matches &&
    matchMedia('(prefers-reduced-motion: no-preference)').matches;

  if (fineAndMotion) {
    document.querySelectorAll<HTMLElement>('.magnetic').forEach((btn) => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width / 2) * 0.25;
        const y = (e.clientY - rect.top - rect.height / 2) * 0.25;
        btn.style.transform = `translate(${x}px, ${y}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });
  }

  // Load full motion orchestration (GSAP + ScrollTrigger + SplitText + tilt)
  import('../scripts/motion.client');
</script>

<style>
  /* ========== Helpers ========== */
  .grain-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  /* ========== SECTION 1 — HERO ========== */
  .hero {
    padding: clamp(96px, 13vw, 160px) 1.5rem clamp(96px, 11vw, 140px);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-inner {
      grid-template-columns: 61.8fr 38.2fr;
      gap: 4rem;
    }
  }

  .authority-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid rgba(232, 230, 220, 0.2);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-ash);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: border-color 200ms ease, color 200ms ease;
  }

  .authority-badge:hover {
    border-color: var(--color-amber);
    color: var(--color-cream);
  }

  .authority-badge strong {
    color: var(--color-cream);
    font-weight: 600;
  }

  .authority-badge-icon {
    width: 16px;
    height: 16px;
    color: var(--color-amber);
  }

  .kinetic-headline {
    margin: 0 0 1.75rem;
    font-size: clamp(38px, 5.4vw, 84px);
    color: var(--color-cream);
  }

  .hero-line {
    display: block;
  }

  .kinetic-word {
    display: inline-block;
    white-space: nowrap;
  }

  .hero-sub {
    font-family: var(--font-body);
    color: var(--color-ash);
    font-size: clamp(1rem, 1.3vw, 1.175rem);
    line-height: 1.6;
    max-width: 58ch;
    margin: 0 0 2.25rem;
  }

  .hero-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .hero-price-pill {
    margin: 0.5rem 0 0;
    padding: 0.35rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-ash);
    letter-spacing: 0.02em;
    border: 1px solid rgba(217, 119, 87, 0.35);
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.06);
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    background: var(--color-amber);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.0625rem;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(217, 119, 87, 0.25);
    transition: background-color 200ms ease, box-shadow 200ms ease, transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: transform;
  }

  .cta-primary:hover {
    background: var(--color-amber-soft);
    box-shadow: 0 12px 32px rgba(217, 119, 87, 0.35);
  }

  .cta-arrow {
    display: inline-block;
    transition: transform 200ms ease;
  }

  .cta-primary:hover .cta-arrow {
    transform: translateX(3px);
  }

  .cta-secondary {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-ash);
    text-decoration: underline;
    text-decoration-color: rgba(176, 174, 165, 0.35);
    text-underline-offset: 4px;
    transition: color 200ms ease, text-decoration-color 200ms ease;
  }

  .cta-secondary:hover {
    color: var(--color-cream);
    text-decoration-color: var(--color-amber);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .vsl-placeholder {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(232, 230, 220, 0.18);
    background: rgba(250, 249, 245, 0.03);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vsl-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 1px solid var(--color-amber);
  }
  .vsl-corner:nth-child(1) { top: 0; left: 0; border-right: none; border-bottom: none; }
  .vsl-corner:nth-child(2) { top: 0; right: 0; border-left: none; border-bottom: none; }
  .vsl-corner:nth-child(3) { bottom: 0; left: 0; border-right: none; border-top: none; }
  .vsl-corner:nth-child(4) { bottom: 0; right: 0; border-left: none; border-top: none; }

  .vsl-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ash);
  }

  /* ========== SECTION 2 — AUTHORITY STRIP ========== */
  .authority-strip {
    background: var(--color-ink);
    padding: clamp(36px, 5vw, 56px) 1.5rem;
    border-top: 1px solid rgba(232, 230, 220, 0.08);
    border-bottom: 1px solid rgba(232, 230, 220, 0.08);
  }

  .authority-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 2rem;
    align-items: end;
  }

  @media (min-width: 768px) {
    .authority-inner {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .authority-item + .authority-item {
      border-left: 1px solid rgba(232, 230, 220, 0.12);
      padding-left: 2rem;
    }
  }

  .authority-num {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 96;
    font-weight: 700;
    font-size: clamp(24px, 2.6vw, 30px);
    color: var(--color-amber);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .authority-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ash);
  }

  /* ========== SECTION 3 — SOUND FAMILIAR ========== */
  .sound-familiar {
    background: var(--color-cream);
    color: var(--color-ink);
    padding: clamp(72px, 10vw, 120px) 1.5rem;
  }

  .sf-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .sf-heading {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 96, 'SOFT' 50;
    font-weight: 600;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 3rem;
  }

  .sf-wall {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .sf-wall {
      grid-template-columns: 60fr 40fr;
      grid-auto-flow: row dense;
    }
    .sf-card-1 { grid-column: 1 / 2; }
    .sf-card-2 { grid-column: 2 / 3; margin-top: 32px; }
    .sf-card-3 { grid-column: 1 / 2; }
    .sf-card-4 { grid-column: 2 / 3; margin-top: 24px; }
  }

  .sf-card {
    background: #ffffff;
    border: 1px solid var(--color-mist);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0;
  }

  .sf-card p {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 72, 'SOFT' 50;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.125rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--color-ink);
    margin: 0;
  }

  .sf-caption {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-stone);
    text-align: right;
    margin: 2.5rem 0 0;
  }

  /* ========== SECTION 6 — DATA-TO-DOLLARS PROCESS ========== */
  .process {
    background: var(--color-cream);
    color: var(--color-ink);
    padding: clamp(72px, 10vw, 120px) 1.5rem;
    border-top: 1px solid var(--color-mist);
  }

  .process-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .process-heading {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 96, 'SOFT' 50;
    font-weight: 600;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 3rem;
  }

  .process-phases {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .phase {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: clamp(1rem, 2vw, 2rem);
    align-items: start;
  }

  @media (max-width: 560px) {
    .phase {
      grid-template-columns: auto 1fr;
    }
    .phase .phase-icon { grid-column: 1; grid-row: 1; }
    .phase .phase-num { grid-column: 2; grid-row: 1; align-self: center; }
