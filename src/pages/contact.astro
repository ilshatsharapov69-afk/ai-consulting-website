---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="Contact"
  description="Book a free 20-minute AI audit call or send a message. No pitch, no pressure — just an honest conversation about your business."
  breadcrumbs={[{ name: 'Contact', url: '/contact/' }]}
>
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-4">Talk to Me — No Pitch, Just Findings</h1>
        <p class="text-lg text-gray-600">
          Free 20-min call. Every HVAC owner gets their top 3 money leaks identified — based on
          your business size, software stack, and team. Even if you never hire me, you walk away
          with actionable numbers.
        </p>
      </div>

      {Astro.url.searchParams.get('success') === 'true' && (
        <div class="mb-8 p-4 bg-green/10 border border-green rounded-lg text-center">
          <p class="text-navy"><strong>Message sent.</strong> I'll respond within 24 hours.</p>
        </div>
      )}

      <!-- Contact Form (full width) -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8 mb-12">
        <h2 class="text-xl font-bold text-navy mb-6">Send a Message</h2>
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
          <input type="hidden" name="access_key" value={SITE.formApiKey} />
          <input type="hidden" name="subject" value="New Contact from Website" />
          <input type="hidden" name="redirect" value={`${SITE.url}/contact/?success=true`} />

          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue focus:border-blue text-base"
                placeholder="John Smith"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue focus:border-blue text-base"
                placeholder="john@company.com"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company</label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue focus:border-blue text-base"
                placeholder="Smith HVAC"
              />
            </div>

            <div>
              <label for="trade" class="block text-sm font-medium text-gray-700 mb-1">Trade</label>
              <select
                id="trade"
                name="trade"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue focus:border-blue text-base bg-white"
              >
                <option value="">Select your trade</option>
                <option value="HVAC">HVAC</option>
                <option value="Electrical">Electrical</option>
                <option value="Plumbing">Plumbing</option>
                <option value="General Contractor">General Contractor</option>
                <option value="Roofing">Roofing</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue focus:border-blue text-base"
              placeholder="Tell me about your biggest operational challenge..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3 rounded-lg bg-green text-white font-semibold hover:bg-green-light transition-colors"
          >
            Send Message
          </button>

          <p class="text-sm text-gray-500 text-center">No spam, no mailing list. I respond personally within 24 hours.</p>
        </form>
      </div>

      <!-- What Happens Next -->
      <div class="mb-12">
        <h2 class="text-xl font-bold text-navy mb-6 text-center">What Happens After You Reach Out</h2>
        <div class="space-y-4">
          {[
            { n: 1, title: 'I respond within 24 hours', desc: 'You\'ll hear back from me personally — not a bot, not an assistant.' },
            { n: 2, title: 'We schedule a 20-minute call', desc: 'At a time that works for you. Morning, evening, whatever fits your schedule.' },
            { n: 3, title: 'On the call, I identify your top 3 money leaks', desc: 'Based on what you tell me about your business, I\'ll point out the most common areas where contractors in your position lose money.' },
            { n: 4, title: 'You decide if the full analysis makes sense', desc: 'If it does, great. If not, you still walk away with useful insights. No pressure either way.' },
          ].map((step) => (
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 rounded-full bg-blue text-white flex items-center justify-center font-bold text-sm">
                {step.n}
              </div>
              <div>
                <h3 class="font-semibold text-navy">{step.title}</h3>
                <p class="text-gray-600 text-sm">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-12">
        <h2 class="text-xl font-bold text-navy mb-6 text-center">Common Questions About the Call</h2>
        <div class="space-y-3">
          <details>
            <summary>"Is the call a sales pitch?"</summary>
            <div>
              No. I'll ask about your business, identify where you're likely losing money, and give you
              real insights — even if you never hire me. If AI analysis makes sense for your situation,
              I'll mention it. If it doesn't, I'll say so.
            </div>
          </details>
          <details>
            <summary>"How should I prepare?"</summary>
            <div>
              No prep needed. Just know your rough annual revenue, team size, and the main software
              tools you use (QuickBooks, scheduling app, etc.). That's enough for me to give you
              useful feedback on the call.
            </div>
          </details>
          <details>
            <summary>"Can I send questions by email instead?"</summary>
            <div>
              Absolutely. Send me an email at
              <a href={`mailto:${SITE.email}`} class="text-blue font-medium">{SITE.email}</a>
              and I'll respond within 24 hours. Some people prefer to write things out first —
              that works too.
            </div>
          </details>
          <details>
            <summary>"I'm not sure AI is relevant for my business."</summary>
            <div>
              That's exactly what the call is for. In 20 minutes, I can tell you whether AI
              analysis would actually find meaningful savings in your operation — or whether
              you should focus on other things first. No risk in finding out.
            </div>
          </details>
        </div>
      </div>

      <!-- Direct contact -->
      <div class="text-center p-6 bg-gray-50 rounded-xl">
        <p class="text-gray-600 mb-2">
          Prefer email? Reach me directly at
        </p>
        <a href={`mailto:${SITE.email}`} class="text-blue font-semibold text-lg">{SITE.email}</a>
      </div>
    </div>
  </section>

  <!--
    Cal.com Integration (for future use):
    When you have a Cal.com account, uncomment the code below and add it above the contact form.
    Replace YOUR_LINK with your Cal.com booking link.

    <div class="mb-12">
      <h2 class="text-xl font-bold text-navy mb-4">Book a Call</h2>
      <div id="cal-embed" style="width:100%;height:500px;overflow:scroll"></div>
      <script>
        (function (C, A, L) {
          let p = function (a, ar) { a.q.push(ar); };
          let d = C.document;
          C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments;
            if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true; }
            if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1];
              api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
              return; }
            p(cal, ar);
          };
        })(window, "https://app.cal.com/embed/embed.js", "init");
        Cal("init", {origin:"https://app.cal.com"});
        Cal("ui", {"theme":"light","styles":{"branding":{"brandColor":"#059669"}}});
        Cal("inline", {calLink: "YOUR_LINK", elementOrSelector: "#cal-embed"});
      </script>
    </div>
  -->
</BaseLayout>
