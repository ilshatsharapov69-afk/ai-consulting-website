---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import CTABlock from '../components/CTABlock.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="About"
  description="10+ years in construction. Now I use AI to help contractors find where their business is losing money — and show them the numbers to prove it."
  breadcrumbs={[{ name: 'About', url: '/about/' }]}
>
  <JsonLd type="organization" />
  <JsonLd type="person" data={{ description: '10+ years in construction. Now helps contractors find where their business is losing money using AI analysis.' }} />

  <!-- Hero with photo placeholder -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        <!-- TODO: replace placeholder silhouette with real headshot (/public/images/ilshat.jpg) -->
        <div class="md:col-span-1">
          <div class="w-full aspect-square rounded-2xl bg-navy/5 flex items-center justify-center">
            <svg class="w-24 h-24 text-navy/30" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
        </div>

        <!-- Introduction -->
        <div class="md:col-span-2">
          <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-6">
            I Help Contractors Find Where They're Losing Money
          </h1>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              I spent 10+ years in the construction industry. I've seen the same problems everywhere:
              missed calls that cost thousands, estimates that take forever, scheduling chaos that eats into
              profits, and office staff drowning in paperwork.
            </p>
            <p>
              The frustrating part? Most of these problems are invisible. You're busy all year, the trucks
              are rolling, the jobs are getting done — but the numbers don't show it. The money is leaking
              somewhere, and nobody has time to find where.
            </p>
            <p>
              That's what I do now. I use AI to analyze contractor businesses — calls, estimates, scheduling,
              finances — and find patterns that no person has time to look for. Then I put it all in a report
              with specific dollar amounts, so you know exactly what to fix and in what order.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why I Started This -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-6">Why I Started This</h2>
      <div class="space-y-4 text-gray-600 leading-relaxed">
        <p>
          After a decade in construction, I saw the same pattern repeat in every company I worked with:
          talented people doing great work, but losing money in places they couldn't see. Missed follow-ups,
          inconsistent estimating, scheduling gaps, after-hours calls going to voicemail.
        </p>
        <p>
          When AI tools became powerful enough to process thousands of data points in minutes, I realized
          something: <strong class="text-navy">the technology to find these leaks already exists — most
          contractors just don't know it's there.</strong>
        </p>
        <p>
          So I combined my construction industry experience with AI analysis tools. I understand this
          industry from the inside — I know that your "office manager" is often your spouse doing dispatch
          and bookkeeping after the kids go to bed. I know your tech budget needs to survive the slow season.
          And I know that a tool your team won't use is worse than no tool at all.
        </p>
      </div>
    </div>
  </section>

  <!-- The Process -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">How I Work: The 3-Step Analysis</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">1</div>
          <h3 class="font-bold text-navy mb-2">Collect</h3>
          <p class="text-gray-600 text-sm">
            I pull data from your existing systems — QuickBooks, scheduling app, call logs, CRM.
            No extra work for you, no new software to install.
          </p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">2</div>
          <h3 class="font-bold text-navy mb-2">Analyze</h3>
          <p class="text-gray-600 text-sm">
            AI processes your data — call patterns, estimate timelines, scheduling efficiency,
            financial trends. It finds patterns that humans don't have time to see.
          </p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">3</div>
          <h3 class="font-bold text-navy mb-2">Report</h3>
          <p class="text-gray-600 text-sm">
            You get a detailed PDF with specific dollar amounts, scored opportunities, and a
            prioritized action plan. We walk through every finding on a 60-minute call.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why AI Analysis -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">Why AI Analysis?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Speed</h3>
          <p class="text-gray-600 text-sm">What takes a human analyst 2-3 weeks, AI processes in hours. We analyze patterns across thousands of records — calls, jobs, finances — simultaneously.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Volume</h3>
          <p class="text-gray-600 text-sm">A person can review maybe 50 records in a day. AI processes your entire year of data — every call, every estimate, every invoice — and cross-references all of it.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Patterns</h3>
          <p class="text-gray-600 text-sm">AI finds connections that aren't obvious: scheduling gaps on specific days, estimates that consistently run over for certain job types, customer follow-ups that fall through the cracks.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Objectivity</h3>
          <p class="text-gray-600 text-sm">No opinions, no guesses. Every finding in the report comes with a specific dollar amount and the data to back it up.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">Background</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">10+ Years in Construction</h3>
            <p class="text-gray-600 text-sm">Hands-on experience in the industry. I understand contractor workflows, pain points, and business models from the inside.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">AI & Data Analysis</h3>
            <p class="text-gray-600 text-sm">Specialized in applying AI tools to business operations analysis — turning raw business data into actionable insights with dollar amounts.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">YouTube: Free AI Tips for Contractors</h3>
            <p class="text-gray-600 text-sm">I share free AI implementation tips and tool reviews for contractors on my YouTube channel.</p>
            {SITE.social.youtube && (
              <a
                href={SITE.social.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-2 text-sm text-blue font-medium no-underline hover:underline"
              >
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                Watch on YouTube →
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools & Platforms -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider text-center mb-6">Tools & Platforms I Work With</h3>
      <div class="flex flex-wrap justify-center gap-6 text-gray-400">
        {[
          'QuickBooks',
          'ServiceTitan',
          'Buildertrend',
          'Housecall Pro',
          'ChatGPT',
          'Claude AI',
          'Google Workspace',
          'Zapier',
        ].map((tool) => (
          <span class="text-sm font-medium px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-600">
            {tool}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABlock headline="Want to See What AI Finds in Your Business?" description="Book a free 20-minute call. No pitch — just an honest conversation about whether this makes sense for you." />
</BaseLayout>
