---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import CTABlock from '../components/CTABlock.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="About"
  description="10+ years running ops teams. Now I help small business owners find where their business is losing money — using AI on their own data. Any industry."
  breadcrumbs={[{ name: 'About', url: '/about/' }]}
>
  <JsonLd type="organization" />
  <JsonLd type="person" data={{ description: '10+ years running ops teams. Now helps small business owners find where their business is losing money using AI on their own data.' }} />

  <!-- Hero with photo placeholder -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        <!-- TODO: replace placeholder silhouette with real headshot (/public/images/ilshat.jpg) -->
        <div class="md:col-span-1">
          <div class="w-full aspect-square rounded-2xl bg-navy/5 flex items-center justify-center">
            <svg class="w-24 h-24 text-navy/30" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
        </div>

        <!-- Introduction -->
        <div class="md:col-span-2">
          <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-6">
            I Help Small Business Owners Find Where They're Losing Money
          </h1>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              I spent 10+ years running construction crews in Russia — 50-person teams,
              fighting paperwork, tracking materials, chasing invoices. Same operational pain every
              small business has, just in different spreadsheets.
            </p>
            <p>
              The problems I saw there show up everywhere: missed follow-ups, inconsistent pricing,
              scheduling chaos, office staff drowning in admin, money leaking through tasks nobody
              has time to look at. Whether you run a restaurant, an e-commerce store, a law practice,
              or a home services business — the shape of the mess is the same.
            </p>
            <p>
              That's what I do now. I plug AI into whatever data a small business generates —
              CRM exports, POS data, spreadsheets, calendar, invoices — and find the patterns that
              no person has time to see. Then I put it all in a report with specific dollar amounts,
              so you know exactly what to fix and in what order.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why I Started This -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-6">Why I Started This</h2>
      <div class="space-y-4 text-gray-600 leading-relaxed">
        <p>
          After a decade running ops in Russia, I noticed a pattern: talented people doing great
          work, but losing money in places they couldn't see. Missed follow-ups, inconsistent
          pricing, scheduling gaps, after-hours inquiries going to voicemail, billable time never
          billed. Every business, every industry.
        </p>
        <p>
          When AI tools became powerful enough to process thousands of data points in minutes,
          I realized something: <strong class="text-navy">the technology to find these leaks
          already exists — most small business owners just don't know it's there, or don't have
          time to figure out how to use it.</strong>
        </p>
        <p>
          So I combined operational experience with AI analysis tools. I understand small business
          from the inside — I know that your "office manager" is often your spouse doing dispatch
          and bookkeeping after the kids go to bed. I know your software budget needs to survive
          the slow season. And I know that a tool your team won't use is worse than no tool at all.
        </p>
      </div>
    </div>
  </section>

  <!-- The Process -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">How I Work: The 3-Step Analysis</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">1</div>
          <h3 class="font-bold text-navy mb-2">Collect</h3>
          <p class="text-gray-600 text-sm">
            I pull data from your existing systems — QuickBooks, Stripe, Toast, Shopify, scheduling
            tools, CRM, spreadsheets. Whatever you have. No new software to install.
          </p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">2</div>
          <h3 class="font-bold text-navy mb-2">Analyze</h3>
          <p class="text-gray-600 text-sm">
            AI processes your data — transaction patterns, customer timelines, scheduling
            efficiency, financial trends. It finds patterns that humans don't have time to see.
          </p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200 text-center">
          <div class="w-14 h-14 rounded-full bg-blue text-white flex items-center justify-center font-bold text-xl mx-auto mb-4">3</div>
          <h3 class="font-bold text-navy mb-2">Report</h3>
          <p class="text-gray-600 text-sm">
            You get a detailed PDF with specific dollar amounts, scored opportunities, and a
            prioritized action plan. We walk through every finding on a 60-minute call.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why AI Analysis -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">Why AI Analysis?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Speed</h3>
          <p class="text-gray-600 text-sm">What takes a human analyst 2-3 weeks, AI processes in hours. We analyze patterns across thousands of records — transactions, customers, schedules — simultaneously.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Volume</h3>
          <p class="text-gray-600 text-sm">A person can review maybe 50 records in a day. AI processes your entire year of data — every transaction, every customer interaction, every invoice — and cross-references all of it.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Patterns</h3>
          <p class="text-gray-600 text-sm">AI finds connections that aren't obvious: scheduling gaps on specific days, quotes that consistently run over for certain service types, customers who churn after a specific interaction, inventory that sits too long.</p>
        </div>
        <div class="p-5 bg-white border border-gray-200 rounded-lg">
          <h3 class="font-bold text-navy mb-2">Objectivity</h3>
          <p class="text-gray-600 text-sm">No opinions, no guesses. Every finding in the report comes with a specific dollar amount and the data to back it up.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-8">Background</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">10+ Years Running Ops Teams</h3>
            <p class="text-gray-600 text-sm">I ran construction crews of 50 in Russia — tracking materials, chasing invoices, managing schedules across dozens of active jobs. That's where I learned small business operational pain is universal: same mess, different spreadsheets, across every industry.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">AI & Data Analysis</h3>
            <p class="text-gray-600 text-sm">Specialized in applying AI tools to business operations analysis — turning raw business data (CRM exports, POS data, spreadsheets, financial records) into actionable insights with dollar amounts.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-4 rounded-lg border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-lg bg-navy/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-navy">YouTube: Free AI Tips for Small Business</h3>
            <p class="text-gray-600 text-sm">I share free AI implementation tips, tool reviews, and real audit breakdowns for small business owners on my YouTube channel.</p>
            {SITE.social.youtube && (
              <a
                href={SITE.social.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 mt-2 text-sm text-blue font-medium no-underline hover:underline"
              >
                <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                Watch on YouTube →
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-4">Industries I've Audited or Can Audit</h2>
      <p class="text-gray-600 mb-8 leading-relaxed">
        The method is the same across industries: pull your data, find the patterns, cost the leaks.
        What changes is the data source. Here's where it works well:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { title: 'Service Trades', desc: 'HVAC, plumbing, electrical, cleaning, lawn care, handyman. Data sources: ServiceTitan, Housecall Pro, Jobber, call logs, QuickBooks.' },
          { title: 'Restaurants & Food Service', desc: 'Full-service, QSR, catering, food trucks. Data sources: Toast, Square for Restaurants, inventory sheets, supplier invoices.' },
          { title: 'E-commerce & Retail', desc: 'Online stores, brick-and-mortar, multi-channel. Data sources: Shopify, WooCommerce, Klaviyo, POS, inventory management.' },
          { title: 'Professional Services', desc: 'Accounting, legal, consulting, agencies. Data sources: CRMs, billing systems (Clio, QuickBooks, FreshBooks), time-tracking.' },
          { title: 'Construction & Remodeling', desc: 'GCs, specialty contractors, home builders. Data sources: Buildertrend, CoConstruct, estimates, job costs.' },
          { title: 'Home Services (General)', desc: 'Pest control, appliance repair, moving, security. Data sources: scheduling apps, call logs, customer records.' },
          { title: 'Fitness & Wellness', desc: 'Gyms, studios, spas, clinics. Data sources: Mindbody, ClassPass, membership systems, booking data.' },
          { title: 'Healthcare Clinics', desc: 'Dental, chiropractic, physical therapy, veterinary. Data sources: practice management software, appointment data, claims.' },
        ].map((item) => (
          <div class="p-4 bg-white rounded-lg border border-gray-200">
            <h3 class="font-bold text-navy mb-1 text-sm">{item.title}</h3>
            <p class="text-gray-600 text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-gray-500 text-sm mt-6 italic">
        Don't see yours? If your business generates data and you have 500K+ in annual revenue, the
        method probably works. Book a free call to find out.
      </p>
    </div>
  </section>

  <!-- Tools & Platforms -->
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider text-center mb-6">Tools & Platforms I Work With</h3>
      <div class="flex flex-wrap justify-center gap-3 text-gray-400">
        {[
          'QuickBooks',
          'Stripe',
          'Shopify',
          'Toast',
          'Square',
          'Salesforce',
          'HubSpot',
          'Clio',
          'Mindbody',
          'ServiceTitan',
          'Housecall Pro',
          'ChatGPT',
          'Claude AI',
          'Google Workspace',
          'Excel',
          'Google Sheets',
          'Notion',
          'Airtable',
          'Calendly',
          'Zapier',
          'Make',
        ].map((tool) => (
          <span class="text-sm font-medium px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-600">
            {tool}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABlock headline="Want to See What AI Finds in Your Business?" description="Book a free 20-minute call. No pitch — just an honest conversation about whether this makes sense for you." />
</BaseLayout>
