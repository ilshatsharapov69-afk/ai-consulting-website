---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE, SERVICES } from '../../config';
---

<BaseLayout
  title="Services"
  description="AI business analysis services for small businesses — from a one-time data audit to ongoing analytics. Any industry. Find exactly where you're losing money."
  breadcrumbs={[{ name: 'Services', url: '/services/' }]}
>
  <!-- Hero -->
  <section class="py-16 bg-navy text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4">
        Every Engagement Starts With Understanding Your Data
      </h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        No cookie-cutter solutions. We start by finding where your small business is losing money,
        then help you fix it — at whatever pace makes sense for you. Any industry.
      </p>
    </div>
  </section>

  <!-- Client Journey -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-4">
        A Clear Path Forward
      </h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        Most small business owners start with the AI Business Analysis. From there, you decide how far to go.
      </p>

      <!-- 3 Service Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: AI Audit (Highlighted) -->
        <div class="relative rounded-2xl border-2 border-blue bg-white p-8 shadow-lg">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-blue text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Start Here</span>
          </div>
          <div class="text-center mb-6">
            <div class="w-14 h-14 rounded-xl bg-blue/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-navy mb-1">AI Business Analysis</h3>
            <div class="text-3xl font-bold text-blue">$2,500</div>
            <div class="text-sm text-gray-500">one-time</div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            We plug AI into your business data — CRM, POS, spreadsheets, whatever you have — and deliver a detailed report showing exactly where money is leaking and what to fix first.
          </p>
          <ul class="space-y-2 mb-6">
            {['12-20 page PDF report', 'AI Readiness Score', '8-15 scored opportunities', '30/60/90 day action plan', '60-minute walkthrough call'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/services/ai-audit/" class="block text-center px-6 py-3 rounded-lg bg-green text-white font-semibold no-underline hover:bg-green-light transition-colors">
            Learn More
          </a>
        </div>

        <!-- Card 2: Deep Dive -->
        <div class="rounded-2xl border border-gray-200 bg-white p-8">
          <div class="text-center mb-6">
            <div class="w-14 h-14 rounded-xl bg-blue/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-navy mb-1">Deep Dive Analysis</h3>
            <div class="text-3xl font-bold text-blue">From $5,000</div>
            <div class="text-sm text-gray-500">project-based</div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            Turn your audit findings into a concrete 90-day plan with specific tools, vendor evaluations, and expected ROI — built from your own data.
          </p>
          <ul class="space-y-2 mb-6">
            {['90-day implementation plan', 'Vendor evaluation matrix', 'Integration architecture', 'Budget & ROI model', 'Team training plan'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/services/roadmap/" class="block text-center px-6 py-3 rounded-lg border border-gray-200 text-navy font-semibold no-underline hover:bg-gray-50 transition-colors">
            Learn More
          </a>
        </div>

        <!-- Card 3: Ongoing Analytics -->
        <div class="rounded-2xl border border-gray-200 bg-white p-8">
          <div class="text-center mb-6">
            <div class="w-14 h-14 rounded-xl bg-blue/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-navy mb-1">Ongoing Analytics</h3>
            <div class="text-3xl font-bold text-blue">From $2,000/mo</div>
            <div class="text-sm text-gray-500">3-month minimum</div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            Hands-on implementation support. We configure AI tools for your business, train your team, and keep everything running smoothly.
          </p>
          <ul class="space-y-2 mb-6">
            {['Monthly strategy calls', 'Tool configuration', 'Team training sessions', 'Priority support', 'Quarterly ROI reviews'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/services/retainer/" class="block text-center px-6 py-3 rounded-lg border border-gray-200 text-navy font-semibold no-underline hover:bg-gray-50 transition-colors">
            Learn More
          </a>
        </div>
      </div>

      <!-- Journey arrows -->
      <div class="flex justify-center items-center gap-4 mt-8 text-gray-400 text-sm">
        <span class="font-medium text-blue">Analysis</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
        <span class="font-medium text-gray-600">Strategy</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
        <span class="font-medium text-gray-600">Implementation</span>
      </div>
    </div>
  </section>

  <!-- Not Sure Which Is Right? -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">
        Not Sure Where to Start?
      </h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
            <span class="text-blue font-bold">?</span>
          </div>
          <div>
            <p class="font-semibold text-navy">"I have no idea where my business is losing money."</p>
            <p class="text-gray-600 text-sm mt-1">Start with the <a href="/services/ai-audit/" class="text-blue font-medium">AI Business Analysis</a>. It identifies your top problems with specific dollar amounts.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
            <span class="text-blue font-bold">?</span>
          </div>
          <div>
            <p class="font-semibold text-navy">"I know the problems. I need a plan to fix them."</p>
            <p class="text-gray-600 text-sm mt-1">The <a href="/services/roadmap/" class="text-blue font-medium">Deep Dive Analysis</a> turns findings into a 90-day action plan with specific tools and timelines.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
            <span class="text-blue font-bold">?</span>
          </div>
          <div>
            <p class="font-semibold text-navy">"I have a plan. I need help executing it."</p>
            <p class="text-gray-600 text-sm mt-1">The <a href="/services/retainer/" class="text-blue font-medium">Ongoing Analytics</a> retainer gives you hands-on support: tool setup, team training, and monthly optimization.</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-gray-200">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
            <span class="text-blue font-bold">?</span>
          </div>
          <div>
            <p class="font-semibold text-navy">"I'm not even sure if AI is relevant for my industry."</p>
            <p class="text-gray-600 text-sm mt-1"><a href={SITE.ctaUrl} class="text-blue font-medium">Book a free 20-minute call</a>. We'll tell you honestly if it makes sense — no commitment, no pitch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zero Risk -->
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <svg class="w-6 h-6 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <h3 class="text-xl font-bold text-navy">Zero Risk Guarantee</h3>
      </div>
      <p class="text-gray-600">
        If our AI Business Analysis doesn't identify at least <strong>$25,000 in annual savings opportunities</strong>, we refund the full $2,500. No questions asked.
      </p>
    </div>
  </section>

  <CTABlock />
</BaseLayout>
