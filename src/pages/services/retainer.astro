---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import FAQ from '../../components/FAQ.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE } from '../../config';

const faqs = [
  {
    question: 'What does "Monthly Advisory" actually include?',
    answer: 'Two monthly strategy calls (30-60 min each), ongoing tool optimization, team training sessions as needed, priority email/chat support, vendor management, and quarterly business reviews with updated ROI tracking.',
  },
  {
    question: 'Do I need the Analysis and Roadmap first?',
    answer: 'Yes. The advisory builds on your roadmap — I\'m executing and optimizing the plan we already built. Without that foundation, we\'d be winging it.',
  },
  {
    question: 'How does pricing compare to alternatives?',
    answer: 'An IT consultant costs $3,750-6,250/month. A safety consultant is $2,500-3,500/month. Marketing agencies charge $1,500-2,500/month. At $2,000-5,000/month, our advisory is comparable to these essential services — but focused specifically on operational efficiency through AI.',
  },
  {
    question: 'What\'s the minimum commitment?',
    answer: 'Three months. AI implementation takes time to show compounding results. Most clients stay 12-18 months as we continuously optimize and add new capabilities.',
  },
  {
    question: 'Can I pause or cancel?',
    answer: 'Yes. After the initial 3-month period, you can pause or cancel with 30 days notice. Everything we\'ve built and configured stays yours.',
  },
];
---

<BaseLayout
  title="Ongoing Analytics"
  description="Hands-on AI implementation support for contractors. Monthly strategy calls, tool configuration, team training, and priority support. From $2,000/month."
  breadcrumbs={[{ name: 'Services', url: '/services/' }, { name: 'Ongoing Analytics', url: '/services/retainer/' }]}
>
  <JsonLd type="service" data={{ name: 'Ongoing Analytics', description: 'Ongoing AI implementation support for contractors', price: '2000' }} />
  <JsonLd type="faqPage" data={{ questions: faqs }} />

  <!-- Hero -->
  <section class="py-16 bg-navy text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-blue-light text-sm font-medium mb-4">
        <a href="/services/" class="hover:text-white no-underline">Services</a>
        <span>/</span>
        <span>Ongoing Analytics</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
        Implementation Without Support Fails 73% of the Time
      </h1>
      <p class="text-xl text-gray-300 mb-6 leading-relaxed">
        You have the plan. Now you need someone to make it happen — configure the tools,
        train your team, and keep everything running as your business evolves.
      </p>
      <div class="flex items-baseline gap-2 mb-8">
        <span class="text-4xl font-bold">From $2,000/mo</span>
        <span class="text-gray-400">3-month minimum</span>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href={SITE.ctaUrl} class="inline-flex items-center px-6 py-3 rounded-lg bg-green text-white font-semibold no-underline hover:bg-green-light transition-colors">
          {SITE.ctaText}
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/services/ai-audit/" class="text-gray-300 text-sm font-medium no-underline hover:text-white transition-colors">
          Starting fresh? Begin with the AI Analysis →
        </a>
      </div>
    </div>
  </section>

  <!-- Prerequisite -->
  <section class="py-6 bg-blue/5 border-b border-blue/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-3">
      <svg class="w-5 h-5 text-blue shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-sm text-gray-700">
        This service follows the <a href="/services/ai-audit/" class="text-blue font-medium">AI Business Analysis</a> and
        <a href="/services/roadmap/" class="text-blue font-medium">Deep Dive Analysis</a>.
        We execute the plan we already built together.
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-8">What's Included</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { title: 'Monthly Strategy Calls', desc: 'Two 30-60 minute calls per month to review progress, troubleshoot issues, and plan next steps.', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
          { title: 'Tool Configuration', desc: 'We set up and configure AI tools in your environment. Connect them to your existing software. Make sure everything works.', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
          { title: 'Team Training', desc: 'Hands-on training for your office staff and field crews. Different sessions for different roles. Recorded for future hires.', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
          { title: 'Priority Support', desc: 'Email and chat support with same-day response. When something breaks or you need guidance, I\'m there.', icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z' },
          { title: 'Vendor Management', desc: 'We handle vendor relationships, negotiate pricing, and manage renewals. One less thing on your plate.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
          { title: 'Quarterly Reviews', desc: 'Detailed ROI tracking, progress against roadmap milestones, and updated recommendations based on new AI capabilities.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
        ].map((item) => (
          <div class="p-5 border border-gray-200 rounded-lg">
            <div class="flex items-start gap-3">
              <div class="shrink-0 w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-navy mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- A Typical Month -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">A Typical Month</h2>
      <div class="space-y-6">
        {[
          { week: 'Week 1', title: 'Review & Plan', items: ['Review last month\'s metrics and tool performance', 'Strategy call: what\'s working, what needs adjustment', 'Set priorities for this month'] },
          { week: 'Week 2', title: 'Execute', items: ['Deploy or configure new tools/features', 'Team training session (if scheduled)', 'Integration testing and optimization'] },
          { week: 'Week 3', title: 'Optimize', items: ['Analyze data from tool usage', 'Fine-tune automations and workflows', 'Address any issues or questions'] },
          { week: 'Week 4', title: 'Report & Prepare', items: ['Monthly progress report with key metrics', 'Strategy call: plan next month\'s priorities', 'Vendor review and cost optimization'] },
        ].map((item) => (
          <div class="flex gap-4">
            <div class="shrink-0 w-20 text-right">
              <span class="text-sm font-bold text-blue">{item.week}</span>
            </div>
            <div class="shrink-0 w-px bg-blue/20 relative">
              <div class="absolute top-1 -left-1 w-2.5 h-2.5 rounded-full bg-blue"></div>
            </div>
            <div class="pb-2">
              <h3 class="font-bold text-navy mb-2">{item.title}</h3>
              <ul class="space-y-1">
                {item.items.map((text) => (
                  <li class="text-gray-600 text-sm flex items-start gap-2">
                    <span class="text-blue shrink-0">→</span>
                    {text}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Month 1 vs Month 6 -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy text-center mb-12">The Compound Effect</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 rounded-xl border border-gray-200">
          <div class="text-sm text-gray-500 uppercase tracking-wider mb-2">Month 1</div>
          <h3 class="text-xl font-bold text-navy mb-4">Foundation</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li>First AI tools deployed</li>
            <li>Team getting comfortable with new workflows</li>
            <li>Baseline metrics established</li>
            <li>Early wins visible but small</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl border-2 border-green/30 bg-green/5">
          <div class="text-sm text-green uppercase tracking-wider font-medium mb-2">Month 6</div>
          <h3 class="text-xl font-bold text-navy mb-4">Compounding Returns</h3>
          <ul class="space-y-2 text-sm text-gray-700">
            <li>3-5 AI tools running smoothly</li>
            <li>Team self-sufficient with daily use</li>
            <li>Documented ROI across all implementations</li>
            <li>New opportunities identified from data patterns</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Comparison -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-xl font-bold text-navy mb-4 text-center">How Does This Compare?</h3>
      <p class="text-gray-600 mb-8 text-center">Contractors already pay for external expertise. Here's what similar services cost:</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="text-center p-5 bg-white rounded-lg border border-gray-200">
          <div class="text-xl font-bold text-gray-400">$3,750-6,250/mo</div>
          <div class="text-sm text-gray-500 mt-1">IT Consultant</div>
        </div>
        <div class="text-center p-5 bg-white rounded-lg border border-gray-200">
          <div class="text-xl font-bold text-gray-400">$2,500-3,500/mo</div>
          <div class="text-sm text-gray-500 mt-1">Safety Consultant</div>
        </div>
        <div class="text-center p-5 bg-white rounded-lg border-2 border-blue">
          <div class="text-xl font-bold text-blue">From $2,000/mo</div>
          <div class="text-sm text-navy font-medium mt-1">AI Advisory</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <FAQ questions={faqs} />
  </div>

  <!-- CTA -->
  <CTABlock headline="Ready for Hands-On AI Implementation Support?" description="Start with a free call to discuss whether the advisory retainer is right for your business." />
</BaseLayout>
