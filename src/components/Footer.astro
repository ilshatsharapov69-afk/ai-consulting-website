---
import { SITE, NAV_LINKS } from '../config';

const year = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-lg font-bold mb-3">{SITE.name}</h3>
        <p class="text-gray-300 text-sm leading-relaxed">{SITE.description}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-3">Navigation</h4>
        <ul class="space-y-2">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-white text-sm no-underline transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/resources/roi-calculator/" class="text-gray-300 hover:text-white text-sm no-underline transition-colors">
              ROI Calculator
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-3">Get in Touch</h4>
        <p class="text-gray-300 text-sm mb-4">
          <a href={`mailto:${SITE.email}`} class="text-gray-300 hover:text-white no-underline transition-colors">
            {SITE.email}
          </a>
        </p>
        <div class="flex gap-4">
          {SITE.social.youtube && (
            <a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
          {SITE.social.linkedin && (
            <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-white/10 text-center text-gray-400 text-sm">
      &copy; {year} {SITE.name}. All rights reserved.
    </div>
  </div>
</footer>
