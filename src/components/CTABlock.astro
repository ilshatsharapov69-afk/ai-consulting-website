---
import { SITE } from '../config';

interface Props {
  headline?: string;
  description?: string;
  variant?: 'default' | 'inline';
}

const {
  headline = 'See What AI Finds in Your Business',
  description = 'Book a free 20-minute call. You\'ll walk away knowing your top 3 money leaks — even if you never hire us.',
  variant = 'default',
} = Astro.props;
---

{variant === 'inline' ? (
  <div class="my-8 p-6 bg-gray-50 rounded-xl border border-gray-200 text-center">
    <p class="text-lg font-semibold text-navy mb-2">{headline}</p>
    <a
      href={SITE.ctaUrl}
      class="inline-flex items-center px-5 py-2.5 rounded-lg bg-green text-white font-semibold no-underline hover:bg-green-light transition-colors"
    >
      {SITE.ctaText}
    </a>
    <p class="text-gray-400 text-xs mt-2">No spam. No sales pitch. I respond personally.</p>
  </div>
) : (
  <section class="bg-navy py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{headline}</h2>
      <p class="text-gray-300 text-lg mb-8">{description}</p>
      <a
        href={SITE.ctaUrl}
        class="inline-flex items-center px-8 py-4 rounded-lg bg-green text-white font-semibold text-lg no-underline hover:bg-green-light transition-colors shadow-lg"
      >
        {SITE.ctaText}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
)}
