---
---

<div id="preloader" class="preloader" role="status" aria-live="polite">
  <span class="sr-only">Loading Setpoint</span>
  <div class="preloader-mark" aria-hidden="true">S</div>
  <div class="preloader-track" aria-hidden="true">
    <div class="preloader-bar"></div>
  </div>
</div>

<script is:inline>
  (function () {
    const el = document.getElementById('preloader');
    if (!el) return;
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      el.style.display = 'none';
      document.body.classList.add('preloaded');
      return;
    }
    const hide = function () {
      setTimeout(function () {
        el.classList.add('preloader--done');
        document.body.classList.add('preloaded');
        setTimeout(function () {
          if (el.parentNode) el.parentNode.removeChild(el);
        }, 500);
      }, 400);
    };
    if (document.readyState === 'complete') {
      hide();
    } else {
      window.addEventListener('load', hide, { once: true });
    }
  })();
</script>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-cream);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    transition: opacity 400ms ease, visibility 400ms ease;
  }

  .preloader--done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader-mark {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    font-weight: 900;
    font-size: 72px;
    color: var(--color-amber);
    line-height: 1;
    animation: preloaderMarkIn 500ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .preloader-track {
    width: min(220px, 44vw);
    height: 2px;
    background: rgba(20, 20, 19, 0.08);
    overflow: hidden;
  }

  .preloader-bar {
    width: 0%;
    height: 100%;
    background: var(--color-amber);
    animation: preloaderBar 700ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes preloaderMarkIn {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes preloaderBar {
    from { width: 0%; }
    to { width: 100%; }
  }
</style>
