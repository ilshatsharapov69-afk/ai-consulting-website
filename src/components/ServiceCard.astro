---
interface Props {
  title: string;
  description: string;
  price: string;
  priceNote: string;
  slug: string;
  icon: string;
}

const { title, description, price, priceNote, slug, icon } = Astro.props;

const icons: Record<string, string> = {
  'clipboard-check': 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  'map': 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  'phone': 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
};
---

<div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow group">
  <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
    <svg class="w-6 h-6 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[icon] || icons['clipboard-check']} />
    </svg>
  </div>
  <h3 class="text-xl font-bold text-navy mb-2">{title}</h3>
  <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>
  <div class="mb-4">
    <span class="text-2xl font-bold text-navy">{price}</span>
    <span class="text-gray-500 text-sm ml-1">{priceNote}</span>
  </div>
  <a
    href={`/services/${slug}/`}
    class="inline-flex items-center text-blue font-medium no-underline group-hover:text-navy transition-colors"
  >
    Learn more
    <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</div>
