---
interface Props {
  variant?: 'ekg' | 'candle' | 'spark' | 'dots';
  theme?: 'light' | 'dark';
  class?: string;
}
const { variant = 'ekg', theme = 'light', class: className = '' } = Astro.props;
---

<div class:list={['signal-divider', `sd--${variant}`, `sd--${theme}`, className]} aria-hidden="true">
  <svg viewBox="0 0 1200 64" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    {variant === 'ekg' && (
      <path
        class="sd-draw"
        d="M0 32 L380 32 L420 32 L440 12 L460 52 L480 20 L500 32 L1200 32"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    )}

    {variant === 'candle' && (
      <g class="sd-draw-group">
        {Array.from({ length: 14 }, (_, i) => {
          const x = 80 + i * 80;
          const up = (i * 37) % 3 !== 0;
          const bodyTop = up ? 20 + ((i * 5) % 10) : 34 + ((i * 5) % 8);
          const bodyBot = up ? 34 + ((i * 3) % 10) : 46 + ((i * 3) % 8);
          const color = up ? 'var(--color-sage)' : 'var(--color-amber)';
          return (
            <g class="sd-candle" style={`--i:${i}`}>
              <line x1={x} y1={bodyTop - 6} x2={x} y2={bodyBot + 6} stroke={color} stroke-width="1" />
              <rect x={x - 4} y={bodyTop} width="8" height={bodyBot - bodyTop} fill={color} />
            </g>
          );
        })}
      </g>
    )}

    {variant === 'spark' && (
      <>
        <path
          class="sd-draw"
          d="M0 48 C120 46, 240 50, 360 44 S 600 38, 720 30 S 960 16, 1200 10"
          fill="none"
          stroke="var(--color-sage)"
          stroke-width="1.75"
          stroke-linecap="round"
        />
        <circle class="sd-dot" cx="1200" cy="10" r="3" fill="var(--color-sage)" />
      </>
    )}

    {variant === 'dots' && (
      <g class="sd-dots">
        {Array.from({ length: 60 }, (_, i) => (
          <circle cx={20 + i * 20} cy="32" r="1.25" fill="currentColor" style={`--i:${i}`} />
        ))}
      </g>
    )}
  </svg>
</div>

<style>
  .signal-divider {
    width: 100%;
    padding: 1.5rem 0;
    overflow: hidden;
    background: transparent;
  }

  .signal-divider svg {
    display: block;
    width: 100%;
    height: 64px;
  }

  .sd--light {
    color: var(--color-mist);
    background: var(--color-cream);
  }
  .sd--light .sd-draw,
  .sd--light .sd-dots circle {
    color: var(--color-stone);
  }
  .sd--light .sd-draw[stroke="currentColor"] {
    stroke: var(--color-stone);
  }

  .sd--dark {
    color: rgba(232, 230, 220, 0.18);
    background: var(--color-ink);
  }
  .sd--dark .sd-draw[stroke="currentColor"] {
    stroke: rgba(232, 230, 220, 0.35);
  }

  /* Stroke-draw entrance */
  .sd-draw {
    stroke-dasharray: 2400;
    stroke-dashoffset: 2400;
  }
  .is-visible .sd-draw {
    animation: sdDraw 900ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes sdDraw {
    to { stroke-dashoffset: 0; }
  }

  /* Candles stagger */
  .sd-candle {
    opacity: 0;
    transform-origin: center;
    transform: scaleY(0.2);
  }
  .is-visible .sd-candle {
    animation: sdCandleIn 380ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: calc(var(--i, 0) * 45ms);
  }

  @keyframes sdCandleIn {
    to {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* Dots fade left→right */
  .sd-dots circle {
    opacity: 0;
  }
  .is-visible .sd-dots circle {
    animation: sdDot 600ms ease-out forwards;
    animation-delay: calc(var(--i, 0) * 12ms);
  }

  @keyframes sdDot {
    to { opacity: 0.55; }
  }

  /* Spark endpoint pulse */
  .sd-dot {
    opacity: 0;
    transform: scale(0);
    transform-origin: 1200px 10px;
  }
  .is-visible .sd-dot {
    animation: sdDotPop 400ms cubic-bezier(0.2, 0.8, 0.2, 1) 800ms forwards;
  }

  @keyframes sdDotPop {
    to { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sd-draw { stroke-dashoffset: 0 !important; animation: none !important; }
    .sd-candle, .sd-dots circle, .sd-dot {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
