---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="flex gap-4">
  <div class="shrink-0 w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-bold text-lg">
    {number}
  </div>
  <div>
    <h3 class="text-lg font-bold text-navy mb-1">{title}</h3>
    <p class="text-gray-600 leading-relaxed">{description}</p>
  </div>
</div>
