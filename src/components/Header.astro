---
import { SITE, NAV_LINKS } from '../config';

const currentPath = Astro.url.pathname;
---

<header class="bg-white sticky top-0 z-50 border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="text-navy font-bold text-xl no-underline hover:text-blue transition-colors">
        {SITE.name}
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-md text-sm font-medium no-underline transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-blue bg-blue/5'
                : 'text-gray-600 hover:text-navy hover:bg-gray-50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={SITE.ctaUrl}
          class="ml-4 inline-flex items-center px-4 py-2 rounded-lg bg-green text-white text-sm font-semibold no-underline hover:bg-green-light transition-colors"
        >
          {SITE.ctaText}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-gray-600 hover:text-navy hover:bg-gray-50"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-md text-base font-medium no-underline transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-blue bg-blue/5'
                : 'text-gray-600 hover:text-navy hover:bg-gray-50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={SITE.ctaUrl}
          class="mt-2 text-center px-4 py-2 rounded-lg bg-green text-white font-semibold no-underline hover:bg-green-light transition-colors"
        >
          {SITE.ctaText}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>
