---
import { SITE } from '../config';

interface Props {
  type: 'organization' | 'service' | 'blogPosting' | 'person' | 'faqPage' | 'breadcrumb';
  data?: Record<string, any>;
}

const { type, data = {} } = Astro.props;
const siteUrl = SITE.url;

function getSchema() {
  switch (type) {
    case 'organization': {
      // Unified @graph with cross-referenced @ids — Organization + Person + Service + WebSite.
      // This gives LLMs a clean entity hierarchy to parse and cite.
      const orgId = `${siteUrl}/#organization`;
      const personId = `${siteUrl}/#person`;
      const serviceId = `${siteUrl}/#service`;
      const websiteId = `${siteUrl}/#website`;
      const sameAs = [SITE.social.youtube, SITE.social.linkedin].filter(Boolean);

      return {
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'Organization',
            '@id': orgId,
            name: SITE.name,
            url: siteUrl,
            description: SITE.description,
            founder: { '@id': personId },
            sameAs,
          },
          {
            '@type': 'Person',
            '@id': personId,
            name: 'Ilshat Sharapov',
            jobTitle: 'Data audit consultant',
            description: 'Founder of Setpoint Audit. Runs the Data-to-Dollars Audit for US small businesses doing $500K–$10M.',
            url: `${siteUrl}/about/`,
            worksFor: { '@id': orgId },
            sameAs,
          },
          {
            '@type': 'Service',
            '@id': serviceId,
            name: 'Data-to-Dollars Audit',
            serviceType: 'Small business data audit',
            description: 'A 5-day, $2,500 fixed-price audit that reads a small business\'s existing data (QuickBooks, CRM, calendar, invoices, POS) and surfaces revenue leaks quantified in dollars. Includes a 14-page PDF, 60-minute walkthrough, and a 30/60/90 action plan. Audit-or-refund guarantee.',
            provider: { '@id': orgId },
            areaServed: { '@type': 'Country', name: 'United States' },
            audience: {
              '@type': 'BusinessAudience',
              name: 'US small businesses, $500K–$10M annual revenue',
            },
            offers: {
              '@type': 'Offer',
              price: SITE.priceNumeric,
              priceCurrency: SITE.currency,
              availability: 'https://schema.org/InStock',
              url: siteUrl,
            },
          },
          {
            '@type': 'WebSite',
            '@id': websiteId,
            name: SITE.name,
            url: siteUrl,
            publisher: { '@id': orgId },
          },
        ],
      };
    }

    case 'service':
      return {
        '@context': 'https://schema.org',
        '@type': 'Service',
        name: data.name,
        description: data.description,
        provider: {
          '@type': 'Organization',
          name: SITE.name,
        },
        ...(data.price && {
          offers: {
            '@type': 'Offer',
            price: data.price,
            priceCurrency: 'USD',
          },
        }),
      };

    case 'blogPosting':
      return {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: data.title,
        description: data.description,
        datePublished: data.pubDate,
        ...(data.updatedDate && { dateModified: data.updatedDate }),
        author: {
          '@type': 'Person',
          name: SITE.author,
        },
        publisher: {
          '@type': 'Organization',
          name: SITE.name,
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': data.url,
        },
      };

    case 'person':
      return {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: SITE.author,
        jobTitle: 'AI Implementation Consultant',
        description: data.description || SITE.description,
        url: `${siteUrl}/about/`,
        sameAs: [
          SITE.social.youtube,
          SITE.social.linkedin,
        ].filter(Boolean),
      };

    case 'faqPage':
      return {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: (data.questions || []).map((q: { question: string; answer: string }) => ({
          '@type': 'Question',
          name: q.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: q.answer,
          },
        })),
      };

    case 'breadcrumb':
      return {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: (data.items || []).map((item: { name: string; url: string }, i: number) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.name,
          item: `${siteUrl}${item.url}`,
        })),
      };

    default:
      return null;
  }
}

const schema = getSchema();
const schemas = Array.isArray(schema) && schema.length > 0 && !schema[0]?.['@context'] ? schema : Array.isArray(schema) ? schema : [schema];
---

{schemas.filter(Boolean).map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
