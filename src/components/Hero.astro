---
import { SITE } from '../config';

interface Props {
  title: string;
  subtitle: string;
  showCta?: boolean;
}

const { title, subtitle, showCta = true } = Astro.props;
---

<section class="bg-navy text-white py-16 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6">
          {title}
        </h1>
        <p class="text-lg sm:text-xl text-gray-300 mb-8 leading-relaxed">
          {subtitle}
        </p>
        {showCta && (
          <div>
            <a
              href={SITE.ctaUrl}
              class="inline-flex items-center px-6 py-3 rounded-lg bg-green text-white font-semibold text-lg no-underline hover:bg-green-light transition-colors shadow-lg hover:shadow-xl"
            >
              {SITE.ctaText}
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <p class="text-gray-400 text-sm mt-3">Free. 20 minutes. No pitch.</p>
          </div>
        )}
      </div>
      <div class="hidden lg:flex justify-center">
        <div class="w-full max-w-md aspect-video rounded-2xl bg-white/10 flex items-center justify-center overflow-hidden">
          <!-- Replace with your video embed:
          <iframe width="100%" height="100%" src="https://www.youtube.com/embed/YOUR_VIDEO_ID" frameborder="0" allowfullscreen></iframe>
          -->
          <div class="text-center text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            <span class="text-sm">Your intro video here</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
